# Admin panel password for /admin
ADMIN_PASSWORD=your_admin_password

# Supabase REST API URL (e.g., https://your-project.supabase.co)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase public anonymous key (exposed to the browser)
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key (CRITICAL: admin access, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
