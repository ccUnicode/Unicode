---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import HeroAreaIndividual from "../../components/components-areas/HeroAreaIndividual.astro";

const whatWeLookForData = [
    "Estudiantes con ganas de compartir conocimientos, experiencias y estrategias de estudio.",
    "Personas interesadas en participar en la creación de material académico como resoluciones de exámenes, clases grabadas, guías y otros recursos de apoyo.",
    "Estudiantes con disposición para apoyar en asesorías académicas y actividades formativas.",
    "Personas motivadas en colaborar en talleres, cursos, ponencias y actividades extracurriculares.",
    "Estudiantes interesados en aprender y participar en la gestión de eventos y actividades académicas, desde la planificación, ideación y organización, hasta el control y ejecución de las mismas.",
];

const weValueData = [
    "Actitud colaborativa y vocación de apoyo.",
    "Responsabilidad y compromiso con las actividades asumidas.",
    "Capacidad para explicar desde la experiencia estudiantil.",
    "Interés por mejorar el acceso a material académico para otros estudiantes.",
    "Disposición para trabajar en equipo y aprender continuamente.",
];

const whatYouWinData = [
    "Un espacio para aportar, aprender y crecer académicamente.",
    "Experiencia en creación de contenido académico y trabajo colaborativo.",
    "Oportunidad de impactar positivamente en la formación de otros estudiantes.",
    "Participación activa en un área que busca mejorar la experiencia académica universitaria.",
];

import { projects } from "../../data/projects";

const projectsData = projects.filter((p) => p.area === "acd");

const directorsData = [
    {
        name: "Franz Nuñez",
        linkedin:
            "https://www.linkedin.com/in/franz-pool-nu%C3%B1ez-villazana/",
        imageSrc: "/areas/AreasImages/Franz_Nuñez.webp",
    },
    {
        name: "Marco Gomez",
        linkedin:
            "https://www.linkedin.com/in/marco-sebastian-gomez-felix-00a974361/",
        imageSrc: "/areas/AreasImages/marco_gomez.webp",
    },
];
---

<Layout title="Académica | Áreas UNICODE">
    <Navbar />

    <HeroAreaIndividual
        title="Académica"
        description="El Área Académica planifica y ejecuta iniciativas orientadas al fortalecimiento de la formación universitaria. Su labor se centra en brindar apoyo académico curricular y extracurricular, promoviendo espacios de acompañamiento, orientación y refuerzo que contribuyan a 
        mejorar el rendimiento estudiantil y disminuir las dificultades presentes en los cursos. Asimismo, impulsa actividades de formación complementaria que permiten desarrollar competencias técnicas y habilidades profesionales, enfocadas en mejorar el desempeño académico de los estudiantes. También promueve la creación y difusión de recursos educativos que amplían el acceso al conocimiento y fomentan el aprendizaje continuo, consolidando así una cultura de excelencia, compromiso y crecimiento académico permanente."
        whatWeLookFor={whatWeLookForData}
        weValue={weValueData}
        whatYouWin={whatYouWinData}
        projects={projectsData}
        directors={directorsData}
    />
</Layout>
