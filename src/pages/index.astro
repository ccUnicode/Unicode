---
import Layout from "../layouts/layout.astro";
import Navbar from "../components/navbar.astro";
import Hero from "../components/hero.astro";
import Stats from "../components/components-home/stats.astro";
import Novedades from "../components/components-home/novedades.astro";
import Nosotros from "../components/components-home/nosotros.astro";
import Alianzas from "../components/components-home/alianzas.astro";
import ExploraUnicode from "../components/components-home/explora-unicode.astro";
import Presidentes from "../components/components-home/presidentes.astro";
---

<Layout title="Inicio">
	<Navbar />
	<Hero />

	<main class="w-full">
		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<Stats />

		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<Novedades />

		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<Nosotros />

		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<Alianzas />

		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<ExploraUnicode />

		<div
			class="w-full h-px bg-linear-to-r from-transparent via-zinc-800 to-transparent"
		>
		</div>

		<Presidentes />
	</main>
</Layout>
