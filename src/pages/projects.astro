---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

// Mock data for projects
const projects = [
  { id: 1, title: "Proyecto Ejemplo 1", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Activo", faculty: "DCC" },
  { id: 2, title: "Proyecto Ejemplo 2", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Activo", faculty: "DCC" },
  { id: 3, title: "Proyecto Ejemplo 3", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Activo", faculty: "DCC" },
  { id: 4, title: "Proyecto Ejemplo 4", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Culminado", faculty: "DCC" },
  { id: 5, title: "Proyecto Ejemplo 5", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Culminado", faculty: "DCC" },
  { id: 6, title: "Proyecto Ejemplo 6", description: "Descripción breve del proyecto realizado por la comunidad UNICODE.", status: "Culminado", faculty: "DCC" },
];

const featuredProjects = projects.slice(0, 3);
---

<Layout title="Proyectos | UNICODE">
  <Navbar />
  
  <main class="min-h-screen bg-[#0a0a0a] text-white pt-24 pb-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col items-center">
      
      <!-- Page Header -->
      <section class="text-center mb-16 animate-fade-in">
        <h1 class="text-5xl md:text-7xl font-bold text-unicode tracking-tighter mb-8 drop-shadow-[0_0_15px_rgba(117,211,45,0.3)]">
          PROYECTOS
        </h1>
        
        <!-- Search and Filter Bar -->
        <div class="flex flex-col md:flex-row gap-4 items-center justify-center mb-6">
          <div class="relative w-full max-w-xl group">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-unicode transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </span>
            <input 
              type="text" 
              placeholder="Buscar proyectos ..." 
              class="w-full bg-zinc-900/50 border border-zinc-800 rounded-full py-3 px-12 focus:outline-none focus:border-unicode transition-all placeholder:text-zinc-600"
            />
          </div>
          
          <button class="flex items-center gap-2 bg-zinc-900/50 border border-zinc-800 rounded-full px-6 py-3 hover:border-unicode transition-colors text-zinc-400 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Filtros
          </button>
        </div>
        
        <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto italic">
          Impulsando el desarrollo de sistemas tech para la formación educativa de nuestros estudiantes
        </p>
      </section>

      <!-- Featured Projects Carousel/Stack -->
      <section class="w-full mb-32 relative">
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-0">
          <!-- Side Project 1 -->
          <div class="hidden md:block w-[300px] h-[400px] bg-zinc-900/40 rounded-3xl border border-zinc-800 scale-90 blur-[1px] opacity-60 overflow-hidden transform -rotate-3 -translate-x-8">
            <div class="w-full h-full bg-linear-to-t from-black to-transparent flex items-end p-6">
              <div class="w-12 h-12 bg-zinc-800 rounded-lg animate-pulse"></div>
            </div>
          </div>

          <!-- Central Project -->
          <div class="w-full max-w-[500px] h-[350px] md:h-[450px] bg-zinc-900/80 rounded-3xl border-2 border-unicode shadow-unicode-lg relative overflow-hidden z-10 transition-transform hover:scale-105 duration-500">
            <div class="absolute inset-0 bg-[url('/placeholder-projects.jpg')] bg-cover bg-center grayscale-50 opacity-40"></div>
            <div class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-transparent p-8 flex flex-col justify-end">
              <div class="flex gap-2 mb-4">
                <span class="px-3 py-1 bg-unicode/20 border border-unicode/30 rounded-full text-[10px] text-unicode uppercase font-bold tracking-widest">Destacado</span>
              </div>
              <h3 class="text-3xl font-bold mb-4">Cargando proyecto...</h3>
            </div>
          </div>

          <!-- Side Project 2 -->
          <div class="hidden md:block w-[300px] h-[400px] bg-zinc-900/40 rounded-3xl border border-zinc-800 scale-90 blur-[1px] opacity-60 overflow-hidden transform rotate-3 translate-x-8">
            <div class="w-full h-full bg-linear-to-t from-black to-transparent flex items-end p-6">
              <div class="w-12 h-12 bg-zinc-800 rounded-lg animate-pulse"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Main Project List -->
      <section class="w-full max-w-7xl">
        <h2 class="text-4xl font-bold mb-12">
          Lista de <span class="text-unicode">proyectos</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map(project => (
            <article class="bg-zinc-900/30 border border-zinc-800/50 rounded-4xl p-6 hover:bg-zinc-800/40 transition-all group border-b-4 border-b-transparent hover:border-b-unicode duration-500">
              <div class="aspect-square bg-zinc-800 rounded-2xl mb-6 overflow-hidden relative">
                <!-- Placeholder for Image -->
                <div class="absolute inset-0 flex items-center justify-center opacity-20">
                  <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-unicode"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
                <!-- Status Badge -->
                <div class="absolute top-4 right-4">
                   <div class={`flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium ${project.status === 'Activo' ? 'bg-zinc-950/80 text-unicode' : 'bg-zinc-950/80 text-rose-500'}`}>
                    <span class={`w-2 h-2 rounded-full ${project.status === 'Activo' ? 'bg-unicode shadow-[0_0_8px_#75D32D]' : 'bg-rose-500 animate-pulse'}`}></span>
                    {project.status}
                   </div>
                </div>
              </div>

              <h3 class="text-xl font-bold mb-3 group-hover:text-unicode transition-colors tracking-tight">
                {project.title}
              </h3>
              
              <p class="text-zinc-500 text-sm mb-6 line-clamp-3">
                {project.description}
              </p>

              <div class="flex items-center justify-between mt-auto pt-4 border-t border-zinc-800/50">
                <div class="flex items-center gap-2 text-zinc-500 text-xs font-semibold">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-unicode"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.5-1 1-4c2 0 3 .5 3 .5s2-1 2-1V3c1 0 3 .5 3 .5s2-1 2-1v5c.5 0 2 1 2 1s1 1 1 3"/></svg>
                  {project.faculty}
                </div>
                
                <a href="#" class="text-xs font-bold py-2 px-6 rounded-full border border-zinc-700 hover:border-unicode hover:text-unicode transition-all">
                  Ver detalles
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

    </div>
  </main>

  <style>
    .animate-fade-in {
      animation: fadeIn 1s ease-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</Layout>
