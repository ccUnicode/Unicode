---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ProjectCard from "../components/components-projects/ProjectCard.astro";
import ProjectSlider from "../components/components-projects/ProjectSlider.astro";
import ProjectFilters from "../components/components-projects/ProjectFilters.astro";

// Mock data for projects
const projects = [
  {
    id: 1,
    title: "SGA Unicode",
    description:
      "Sistema de Gestión Académica para la automatización de procesos internos.",
    status: "Activo",
    faculty: "DCC",
    category: "Destacado",
    image: "/bienvenida_cachimbos.png",
  },
  {
    id: 2,
    title: "Unicode Web",
    description:
      "Portal oficial de la comunidad UNICODE construido con Astro y Tailwind CSS.",
    status: "Activo",
    faculty: "DCC",
    category: "Destacado",
    image: "/bienvenida_cachimbos.png",
  },
  {
    id: 3,
    title: "App Matrícula",
    description:
      "Aplicación móvil para facilitar el proceso de matrícula de los estudiantes.",
    status: "Activo",
    faculty: "DCC",
    category: "Destacado",
    image: "/bienvenida_cachimbos.png",
  },
  {
    id: 4,
    title: "Blockchain Voting",
    description:
      "Sistema de votación transparente utilizando tecnología blockchain.",
    status: "Culminado",
    faculty: "DCC",
    category: "Destacado",
    image: "/bienvenida_cachimbos.png",
  },
  {
    id: 5,
    title: "AI Tutor",
    description:
      "Asistente virtual de aprendizaje basado en inteligencia artificial.",
    status: "Culminado",
    faculty: "DCC",
    category: "Destacado",
    image: "/bienvenida_cachimbos.png",
  },
  {
    id: 6,
    title: "IoT Smart Lab",
    description:
      "Monitoreo y control de laboratorios mediante dispositivos IoT.",
    status: "Activo",
    faculty: "DCC",
    image: "/convocatoria_bg.png",
  },
  {
    id: 7,
    title: "DataViz Dashboard",
    description:
      "Visualización de datos académicos para la toma de decisiones.",
    status: "Culminado",
    faculty: "DCC",
    image: "/convocatoria_bg.png",
  },
];

const featuredProjects = projects.filter((p) => p.category === "Destacado");
---

<Layout title="Proyectos">
  <Navbar />

  <main
    class="min-h-screen bg-[#0a0a0a] text-white pt-24 pb-20 overflow-x-hidden"
  >
    <!-- Page Header -->
    <section class="max-w-7xl mx-auto px-6 text-center mb-16 animate-fade-in">
      <h1
        class="text-5xl md:text-7xl font-bold text-unicode tracking-tighter mb-8 drop-shadow-[0_0_15px_rgba(117,211,45,0.3)]"
      >
        PROYECTOS
      </h1>

      <div class="flex justify-center">
        <ProjectFilters />
      </div>

      <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto italic mt-4">
        Impulsando el desarrollo de sistemas tech para la formación educativa de
        nuestros estudiantes
      </p>
    </section>

    <!-- Featured Projects Slider -->
    <section
      id="featured-section"
      class="w-full mb-32 animate-fade-in"
      style="animation-delay: 200ms;"
    >
      <div class="max-w-7xl mx-auto px-6 mb-8">
        <h2 class="text-2xl font-bold flex items-center gap-3">
          <span class="w-8 h-[2px] bg-unicode"></span>
          PROYECTOS DESTACADOS
        </h2>
      </div>
      <ProjectSlider projects={featuredProjects} />
    </section>

    <!-- Main Project List -->
    <section class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-bold mb-12">
        Lista de <span class="text-unicode">proyectos</span>
      </h2>

      <div id="no-results" class="hidden text-center py-20 animate-fade-in">
        <p class="text-zinc-500 text-xl font-medium">
          No se encontraron proyectos que coincidan con tu búsqueda.
        </p>
        <button
          id="clear-search"
          class="mt-4 text-unicode hover:underline text-sm"
          >Limpiar búsqueda</button
        >
      </div>

      <div class="relative group/main-carousel w-full">
        <!-- Container -->
        <div
          id="projects-grid"
          class="flex md:grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 overflow-x-hidden md:overflow-visible pb-4 md:pb-0 scroll-smooth"
        >
          {
            projects.map((project) => (
              <div class="project-item flex-none w-[88vw] md:w-auto h-full snap-center">
                <ProjectCard
                  title={project.title}
                  description={project.description}
                  status={project.status}
                  faculty={project.faculty}
                  image={project.image}
                />
              </div>
            ))
          }
        </div>

        <!-- Carousel arrows & dots (Mobile Only) -->
        <div class="flex md:hidden items-center justify-center gap-6 mt-8">
          <button
            id="prev-main"
            class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg hover:border-unicode/50"
            aria-label="Anterior"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="3"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>

          <div id="main-carousel-indicator" class="flex justify-center gap-3">
            {
              projects.map((_, i) => (
                <button
                  class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-unicode w-6" : "bg-zinc-800"}`}
                  aria-label={`Ir al proyecto ${i + 1}`}
                  data-index={i}
                />
              ))
            }
          </div>

          <button
            id="next-main"
            class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg hover:border-unicode/50"
            aria-label="Siguiente"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="3"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      </div>
    </section>
  </main>

  <style>
    .animate-fade-in {
      animation: fadeIn 1s ease-out forwards;
      opacity: 0;
    }
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    function initSearch() {
      const searchInput = document.getElementById(
        "project-search",
      ) as HTMLInputElement;
      const projectItems = document.querySelectorAll(".project-item");
      const noResults = document.getElementById("no-results");
      const projectsGrid = document.getElementById("projects-grid");
      const clearSearchBtn = document.getElementById("clear-search");
      const featuredSection = document.getElementById("featured-section");

      if (!searchInput || projectItems.length === 0) return;

      const filterProjects = () => {
        const searchTerm = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        // Toggle featured section: hide if searching, show if empty
        if (searchTerm.length > 0) {
          featuredSection?.classList.add("hidden");
        } else {
          featuredSection?.classList.remove("hidden");
        }

        projectItems.forEach((item) => {
          const title =
            item.querySelector("h3")?.textContent?.toLowerCase() || "";
          const description =
            item.querySelector("p")?.textContent?.toLowerCase() || "";

          const isVisible =
            title.includes(searchTerm) || description.includes(searchTerm);

          if (isVisible) {
            (item as HTMLElement).style.display = "block";
            visibleCount++;
          } else {
            (item as HTMLElement).style.display = "none";
          }
        });

        // Re-calculate main carousel index if visible items change
        const mainCarouselIndicator = document.getElementById(
          "main-carousel-indicator",
        );
        if (mainCarouselIndicator) {
          if (searchTerm.length > 0) {
            mainCarouselIndicator.parentElement!.style.display = "none";
          } else {
            mainCarouselIndicator.parentElement!.style.display = "";
          }
        }

        // Toggle no results message
        if (visibleCount === 0) {
          noResults?.classList.remove("hidden");
          projectsGrid?.classList.add("opacity-0");
        } else {
          noResults?.classList.add("hidden");
          projectsGrid?.classList.remove("opacity-0");
        }
      };

      searchInput.addEventListener("input", filterProjects);

      clearSearchBtn?.addEventListener("click", () => {
        searchInput.value = "";
        filterProjects();
        searchInput.focus();
      });
    }

    function initMainCarousel() {
      const container = document.getElementById("projects-grid");
      const indicator = document.getElementById("main-carousel-indicator");

      if (!container || !indicator) return;

      const dots = indicator.querySelectorAll("button");
      const prevBtn = document.getElementById("prev-main");
      const nextBtn = document.getElementById("next-main");

      const scrollStep = () => container.clientWidth;

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener("click", () => {
          container.scrollLeft -= scrollStep();
        });
        nextBtn.addEventListener("click", () => {
          container.scrollLeft += scrollStep();
        });
      }

      container.addEventListener("scroll", () => {
        const scrollIndex = Math.round(
          container.scrollLeft / container.clientWidth,
        );
        dots.forEach((dot, i) => {
          if (i === scrollIndex) {
            dot.classList.add("bg-unicode", "w-6");
            dot.classList.remove("bg-zinc-800");
          } else {
            dot.classList.remove("bg-unicode", "w-6");
            dot.classList.add("bg-zinc-800");
          }
        });
      });

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = parseInt(dot.getAttribute("data-index") || "0");
          container.scrollLeft = index * container.clientWidth;
        });
      });
    }

    // Run on initial load
    initSearch();
    initMainCarousel();

    // Re-initialize after view transitions (if any)
    document.addEventListener("astro:page-load", () => {
      initSearch();
      initMainCarousel();
    });
  </script>
</Layout>
