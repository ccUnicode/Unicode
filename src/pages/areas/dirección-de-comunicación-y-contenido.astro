<Layout title="Dirección de Comunicación y Contenido | Áreas UNICODE">
    <Navbar />

    <HeroAreaIndividual
        title="Dirección de Comunicación y Contenido"
        description="La Dirección de Comunicación y Contenido (DCC) es el motor creativo encargado de traducir el conocimiento técnico de UNICODE en un mensaje claro y de alto impacto. Su labor se centra en diseñar y ejecutar estrategias integrales de marketing, edición audiovisual y redacción editorial que fortalezcan el posicionamiento de la organización. Asimismo, asegura la difusión efectiva de eventos, solucionarios y proyectos tecnológicos para mantener a la comunidad informada y conectada. También potencia las habilidades técnicas y de creación de contenido de sus miembros, formándolos como verdaderos embajadores de marca. Finalmente, transforma conceptos académicos complejos en recursos educativos valiosos que enriquecen el ecosistema estudiantil."
        whatWeLookFor={whatWeLookForData}
        weValue={weValueData}
        whatYouWin={whatYouWinData}
        projects={projectsData}
        directors={directorsData}
    />
</Layout>
