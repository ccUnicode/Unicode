---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import HeroAreaIndividual from "../../components/components-areas/HeroAreaIndividual.astro";

const whatWeLookForData = [
    "Estudiantes responsables y comprometidos (lo más importante).",
    "Apoyo en cobertura de eventos: fotos, clips, highlights y resúmenes.",
    "Tener interés en branding e identidad visual: afiches, plantillas, banners y piezas de difusión.",
    "Ser innovador y creativo para proponer ideas, trabajar en equipo y liderar proyectos.",
];

const weValueData = [
    "Conocimiento y manejo experto de Canva.",
    "Conocimiento en herramientas de edición de imágenes como Illustrator y Photoshop.",
    "Conocimiento en herramientas de edición de video como Filmora y CapCut.",
];

const whatYouWinData = [
    "Experiencia real en creación de contenido y comunicación.",
    "Aprendizaje práctico y trabajo colaborativo.",
    "Participación en proyectos y eventos con impacto en la comunidad.",
    "En caso hayas ingresado al área sin conocimientos previos, te irás con muchos saberes con respecto a diseño, branding y marketing.",
];

import { projects } from "../../data/projects";

const projectsData = projects.filter(p => p.area === "dcc");

const directorsData = [
    {
        name: "Renato Gutierrez",
        linkedin: "renato-gutierrez",
        imageSrc: "/AreasImages/Renato_Gutierrez.png",
    },
    {
        name: "Rubí Quispe",
        linkedin: "rubi-quispe-sierra",
        imageSrc: "/AreasImages/Rubi_Quispe.png",
    },
];
---

<Layout title="Dirección de Comunicación y Contenido | Áreas UNICODE">
    <Navbar />

    <HeroAreaIndividual
        title="Dirección de Comunicación y Contenido"
        description="La Dirección de Comunicación y Contenido (DCC) es el motor creativo encargado de traducir el conocimiento técnico de UNICODE en un mensaje claro y de alto impacto. Su labor se centra en diseñar y ejecutar estrategias integrales de marketing, edición audiovisual y redacción editorial que fortalezcan el posicionamiento de la organización. Asimismo, asegura la difusión efectiva de eventos, solucionarios y proyectos tecnológicos para mantener a la comunidad informada y conectada. También potencia las habilidades técnicas y de creación de contenido de sus miembros, formándolos como verdaderos embajadores de marca. Finalmente, transforma conceptos académicos complejos en recursos educativos valiosos que enriquecen el ecosistema estudiantil."
        whatWeLookFor={whatWeLookForData}
        weValue={weValueData}
        whatYouWin={whatYouWinData}
        projects={projectsData}
        directors={directorsData}
    />
</Layout>
