---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = "Centro cultural tecnológico de la FIIS-UNI. Conectamos estudiantes con el mundo tech a través de proyectos, eventos y comunidad.",
	image = "/logos/logo-unicode.webp",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://ccunicode.org");
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Basics -->
		<title>{title} | UNICODE</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.href} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={`${title} | UNICODE`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:site_name" content="UNICODE - Centro Cultural FIIS UNI" />
		<meta property="og:locale" content="es_PE" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${title} | UNICODE`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Extra SEO -->
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#75D32D" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class="bg-[#050505] text-white antialiased min-h-screen flex flex-col font-sans"
	>
		<slot />
		<Footer />
	</body>
</html>
