---
/**
 * Footer.astro (Global)
 * Versión mejorada con estructura multi-columna y estética premium.
 */
const currentYear = new Date().getFullYear();

const navigation = [
  { name: "Inicio", href: "/" },
  { name: "Áreas", href: "/areas" },
  { name: "Eventos", href: "/eventos" },
  { name: "Proyectos", href: "/projects" },
];

const areas = [
  {
    name: "Investigación y Desarrollo",
    href: "/areas/investigación-y-desarrollo",
  },
  { name: "Académica", href: "/areas/académica" },
  { name: "Gestión del Talento", href: "/areas/gestión-del-talento-humano" },
  { name: "Relaciones Públicas", href: "/areas/relaciones-públicas" },
  {
    name: "Comunicación y Contenido",
    href: "/areas/dirección-de-comunicación-y-contenido",
  },
];

const social = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/profile.php?id=61566294032200",
    icon: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path>`,
  },
  {
    name: "Instagram",
    href: "https://www.instagram.com/cc.unicode/",
    icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204 0.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"></path>`,
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/company/ccunicode",
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>`,
  },
];
---

<footer class="bg-[#050505] relative overflow-hidden">
  <!-- Línea de luz superior con glow -->
  <div
    class="absolute top-0 left-0 w-full h-px bg-linear-to-r from-transparent via-unicode/30 to-transparent"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6 pt-24 pb-12 relative z-10">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-20"
    >
      <!-- Columna 1: Marca -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3 group">
          <div
            class="w-12 h-12 rounded-xl bg-zinc-900/50 border border-zinc-800 flex items-center justify-center group-hover:border-unicode/40 transition-all duration-300"
          >
            <img
              src="/logos/logo-unicode-blanco.webp"
              alt="UNICODE Logo"
              class="w-7 h-7 object-contain opacity-80 group-hover:opacity-100 transition-all"
              loading="lazy"
            />
          </div>
          <span
            class="text-xl font-bold tracking-tight text-white group-hover:text-unicode transition-colors"
            >UNICODE</span
          >
        </a>
        <p class="text-zinc-400 text-sm leading-relaxed max-w-xs">
          Comunidad estudiantil de la FIIS UNI dedicada a la innovación,
          desarrollo de software y formación de líderes tecnológicos.
        </p>
        <div class="flex items-center gap-4">
          {
            social.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-lg bg-zinc-900/30 border border-zinc-800/50 flex items-center justify-center text-zinc-500 hover:text-unicode hover:border-unicode/30 hover:bg-unicode/5 transition-all duration-300"
                aria-label={item.name}
              >
                <svg
                  class="w-5 h-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  set:html={item.icon}
                />
              </a>
            ))
          }
        </div>
      </div>

      <!-- Columna 2: Navegación -->
      <div>
        <h3
          class="text-white font-semibold mb-6 text-sm uppercase tracking-widest"
        >
          Navegación
        </h3>
        <ul class="space-y-4">
          {
            navigation.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-zinc-400 hover:text-unicode text-sm transition-colors flex items-center gap-2 group"
                >
                  <span class="w-1 h-px bg-unicode scale-x-0 group-hover:scale-x-100 transition-transform origin-left" />
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 3: Áreas -->
      <div>
        <h3
          class="text-white font-semibold mb-6 text-sm uppercase tracking-widest"
        >
          Nuestras Áreas
        </h3>
        <ul class="space-y-4">
          {
            areas.map((area) => (
              <li>
                <a
                  href={area.href}
                  class="text-zinc-400 hover:text-unicode text-sm transition-colors flex items-center gap-2 group"
                >
                  <span class="w-1 h-px bg-unicode scale-x-0 group-hover:scale-x-100 transition-transform origin-left" />
                  {area.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 4: Contacto / CTA -->
      <div class="space-y-6">
        <h3
          class="text-white font-semibold mb-6 text-sm uppercase tracking-widest"
        >
          Contacto
        </h3>
        <div class="space-y-4">
          <div class="flex items-start gap-3 text-zinc-400 text-sm">
            <svg
              class="w-5 h-5 text-unicode shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span
              >Av. Túpac Amaru 210, Rímac<br />Facultad de Ingeniería Industrial
              y de Sistemas - UNI</span
            >
          </div>
          <div class="flex items-center gap-3 text-zinc-400 text-sm">
            <svg
              class="w-5 h-5 text-unicode shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:ccunicode@gmail.com"
              class="hover:text-white transition-colors">ccunicode@gmail.com</a
            >
          </div>
        </div>

        <!-- Botón CTA -->
        <a
          href="/call"
          class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-unicode/30 bg-unicode/5 text-unicode text-sm font-semibold hover:bg-unicode hover:text-black transition-all duration-300 shadow-unicode-sm hover:shadow-unicode mt-4"
        >
          ¡Únete a nosotros!
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="pt-8 border-t border-zinc-900 flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <p
        class="text-zinc-500 text-[11px] uppercase tracking-[0.2em] font-medium order-2 md:order-1"
      >
        © {currentYear} UNICODE — CENTRO CULTURAL ESTUDIANTIL DE INGENIERÍA
      </p>

      <div class="flex items-center gap-8 order-1 md:order-2">
        <span class="text-zinc-600 text-[10px] tracking-widest uppercase"
          >FIIS — Universidad Nacional de Ingeniería</span
        >
      </div>
    </div>
  </div>

  <!-- Decoración visual de fondo -->
  <div
    class="absolute -bottom-24 -left-24 w-96 h-96 bg-unicode/5 rounded-full blur-[100px] opacity-30"
  >
  </div>
</footer>
