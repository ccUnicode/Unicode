---
/**
 * ProximosEventos.astro
 * Sección de Próximos Eventos con tarjetas detalladas.
 */

interface Evento {
  ponente: string;
  tema: string;
  descripcion: string;
  fecha: string;
  hora: string;
  lugar: string;
  imagenPonente: string;
  imagenFondo: string;
  inscripcionUrl: string;
}

const eventos: Evento[] = [
  {
    ponente: "José Carreón",
    tema: '"Mi experiencia al lado de Steve Jobs"',
    descripcion:
      "Una charla inspiradora donde José Carreón compartirá su experiencia trabajando junto a Steve Jobs, los aprendizajes clave y cómo la innovación transforma industrias enteras.",
    fecha: "20 Nov",
    hora: "2:30 PM",
    lugar: "Auditorio de la FIIS",
    imagenPonente: "/evento_unicode_1.png",
    imagenFondo: "/evento_unicode_2.png",
    inscripcionUrl: "#",
  },
  {
    ponente: "María González",
    tema: '"IA y el futuro de la ingeniería"',
    descripcion:
      "Descubre cómo la inteligencia artificial está revolucionando el campo de la ingeniería industrial y de sistemas. María compartirá casos reales y oportunidades para estudiantes.",
    fecha: "27 Nov",
    hora: "4:00 PM",
    lugar: "Lab. de Cómputo FIIS",
    imagenPonente: "/evento_unicode_1.png",
    imagenFondo: "/evento_unicode_2.png",
    inscripcionUrl: "#",
  },
];
---

<section id="proximos-eventos" class="w-full py-20 md:py-28 bg-[#050505]">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Título de sección -->
    <h2
      class="text-4xl md:text-6xl font-extrabold text-center mb-16 uppercase tracking-tight"
    >
      PRÓXIMOS <span class="text-unicode">EVENTOS</span>
    </h2>

    <!-- Lista de eventos -->
    <div class="flex flex-col gap-16">
      {
        eventos.map((evento) => (
          <article class="relative w-full rounded-3xl overflow-hidden border border-zinc-800/50 group hover:border-unicode/30 transition-all duration-500">
            <!-- Fondo con imagen -->
            <div class="absolute inset-0">
              <img
                src={evento.imagenFondo}
                alt=""
                class="w-full h-full object-cover opacity-30 group-hover:opacity-40 transition-opacity duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/70 to-black/50" />
            </div>

            <!-- Contenido del evento -->
            <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12 p-6 md:p-10">
              {/* Tarjeta del ponente */}
              <div class="shrink-0 w-52 md:w-64">
                <div class="relative rounded-2xl overflow-hidden border-2 border-unicode/40 shadow-unicode group-hover:shadow-unicode-lg transition-all duration-500">
                  <img
                    src={evento.imagenPonente}
                    alt={evento.ponente}
                    class="w-full aspect-[3/4] object-cover"
                  />
                  {/* Overlay inferior con info del ponente */}
                  <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/90 via-black/60 to-transparent p-4">
                    <div class="flex items-center gap-2 mb-1">
                      <svg
                        class="w-3 h-3 text-unicode"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                      </svg>
                      <span class="text-zinc-400 text-[10px] uppercase tracking-widest font-medium">
                        UNICODE
                      </span>
                    </div>
                    <p class="text-white font-bold text-sm leading-tight">
                      {evento.ponente}
                    </p>
                    <div class="flex items-center gap-3 mt-2 text-[10px] text-zinc-400">
                      <span class="flex items-center gap-1">
                        <svg class="w-3 h-3 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" />
                          <line x1="8" y1="2" x2="8" y2="6" />
                          <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        {evento.fecha} - {evento.hora}
                      </span>
                    </div>
                    <div class="flex items-center gap-1 mt-1 text-[10px] text-zinc-400">
                      <svg class="w-3 h-3 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                        <circle cx="12" cy="10" r="3" />
                      </svg>
                      {evento.lugar}
                    </div>
                  </div>
                </div>
              </div>

              {/* Información del evento */}
              <div class="flex-1 text-center md:text-left flex flex-col gap-4">
                <div>
                  <h3 class="text-2xl md:text-4xl font-extrabold text-white">
                    {evento.ponente.split(" ")[0]}{" "}
                    <span class="text-unicode">
                      {evento.ponente.split(" ").slice(1).join(" ")}
                    </span>
                  </h3>
                  <p class="text-lg md:text-xl text-gray-300 font-medium mt-1 italic">
                    {evento.tema}
                  </p>
                </div>

                <div>
                  <h4 class="text-unicode font-bold text-base md:text-lg mb-1">
                    Descripción del evento:
                  </h4>
                  <p class="text-gray-400 text-sm md:text-base leading-relaxed max-w-lg mx-auto md:mx-0">
                    {evento.descripcion}
                  </p>
                </div>

                {/* Datos del evento */}
                <div class="flex flex-wrap gap-4 justify-center md:justify-start text-sm text-gray-300 mt-2">
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    {evento.fecha}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    {evento.hora}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                      <circle cx="12" cy="10" r="3" />
                    </svg>
                    {evento.lugar}
                  </span>
                </div>

                {/* Botón inscríbete */}
                <div class="mt-4">
                  <a
                    href={evento.inscripcionUrl}
                    class="inline-block border-2 border-unicode text-unicode font-bold px-8 py-3 rounded-full hover:bg-unicode hover:text-black transition-all duration-300 hover:shadow-unicode text-sm md:text-base"
                  >
                    Inscríbete
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
