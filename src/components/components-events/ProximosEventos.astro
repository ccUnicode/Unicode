---
/**
 * ProximosEventos.astro
 * Sección de Próximos Eventos con visualización responsiva diferenciada:
 * - Mobile/Tablet: Carrusel interactivo con tarjetas compactas y modales.
 * - PC (Desktop): Lista vertical de tarjetas expandidas (formato original).
 */

interface Evento {
  id: string;
  ponente: string;
  tema: string;
  descripcion: string;
  fecha: string;
  hora: string;
  lugar: string;
  imagenPonente: string;
  imagenFondo: string;
  inscripcionUrl: string;
}

const eventos: Evento[] = [
  {
    id: "evt-1",
    ponente: "José Carreón",
    tema: '"Mi experiencia al lado de Steve Jobs"',
    descripcion:
      "Una charla inspiradora donde José Carreón compartirá su experiencia trabajando junto a Steve Jobs, los aprendizajes clave y cómo la innovación transforma industrias enteras. Descubre los principios de diseño y liderazgo que marcaron una época.",
    fecha: "20 Nov",
    hora: "2:30 PM",
    lugar: "Auditorio de la FIIS",
    imagenPonente: "/evento_unicode_1.png",
    imagenFondo: "/evento_unicode_2.png",
    inscripcionUrl: "#",
  },
  {
    id: "evt-2",
    ponente: "María González",
    tema: '"IA y el futuro de la ingeniería"',
    descripcion:
      "Descubre cómo la inteligencia artificial está revolucionando el campo de la ingeniería industrial y de sistemas. María compartirá casos reales, herramientas actuales y el impacto en el mercado laboral.",
    fecha: "27 Nov",
    hora: "4:00 PM",
    lugar: "Lab. de Cómputo FIIS",
    imagenPonente: "/evento_unicode_1.png",
    imagenFondo: "/evento_unicode_2.png",
    inscripcionUrl: "#",
  },
  {
    id: "evt-3",
    ponente: "Carlos Ruiz",
    tema: '"Cloud Computing y Arquitectura"',
    descripcion:
      "Aprende sobre las mejores prácticas en el despliegue de infraestructuras en la nube. Un recorrido profundo por AWS, Azure y la arquitectura de microservicios moderna.",
    fecha: "05 Dic",
    hora: "3:00 PM",
    lugar: "Aula Magna FIIS",
    imagenPonente: "/evento_unicode_1.png",
    imagenFondo: "/evento_unicode_2.png",
    inscripcionUrl: "#",
  },
];
---

<section id="proximos-eventos" class="w-full py-20 md:py-28 bg-[#050505] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <h2
      class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out text-4xl md:text-6xl font-extrabold text-center mb-16 uppercase tracking-tight"
    >
      PRÓXIMOS <span class="text-unicode">EVENTOS</span>
    </h2>

    <!-- ==========================================
         VISTA MÓVIL Y TABLET (CARRUSEL)
         ========================================== -->
    <div class="lg:hidden relative group/carousel">
      <!-- Contenedor Responsive (Flex carrusel en móvil, Grid en tablet/desktop) -->
      <div 
        id="events-scroll-container"
        class="flex md:grid md:grid-cols-2 gap-6 overflow-x-auto md:overflow-x-visible pb-4 md:pb-0 snap-x snap-mandatory scrollbar-hide scroll-smooth"
      >
        {
          eventos.map((evento, index) => {
            const cleanTema = evento.tema.split('"').join('');
            return (
              <article 
                class="scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out flex-none w-[88vw] md:w-auto relative rounded-3xl overflow-hidden border border-zinc-800/50 group bg-zinc-900/20 snap-center hover:border-unicode/30"
                style={`transition-delay: ${index * 100}ms;`}
                data-evento-json={JSON.stringify(evento)}
              >
                <div class="absolute inset-0 z-0">
                  <img src={evento.imagenFondo} alt="" class="w-full h-full object-cover opacity-20 group-hover:opacity-30 transition-opacity duration-500" />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/80 to-transparent" />
                </div>

                <div class="relative z-10 p-6 md:p-8 flex flex-col h-full">
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-unicode shadow-unicode/20">
                      <img src={evento.imagenPonente} alt={evento.ponente} class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-unicode font-bold text-[10px] uppercase tracking-widest mb-0.5">Speaker</p>
                      <h3 class="text-white font-bold text-base truncate">{evento.ponente}</h3>
                    </div>
                  </div>

                  <h4 class="text-xl font-black text-white leading-tight mb-3 line-clamp-2 min-h-14 group-hover:text-unicode transition-colors">
                    {cleanTema}
                  </h4>

                  <p class="text-zinc-400 text-sm mb-6 line-clamp-3">
                    {evento.descripcion}
                  </p>

                  <div class="mt-auto space-y-2 mb-6">
                    <div class="flex items-center gap-2 text-xs text-zinc-400 font-medium">
                      <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" />
                      </svg>
                      {evento.fecha} • {evento.hora}
                    </div>
                    <div class="flex items-center gap-2 text-xs text-zinc-400 font-medium whitespace-nowrap overflow-hidden">
                      <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
                      </svg>
                      <span class="truncate">{evento.lugar}</span>
                    </div>
                  </div>

                  <button 
                    class="open-modal-btn w-full py-3 bg-unicode/10 hover:bg-unicode text-unicode hover:text-black font-bold text-xs uppercase tracking-widest rounded-xl border border-unicode/30 transition-all duration-300"
                  >
                    Ver más
                  </button>
                </div>
              </article>
            );
          })
        }
      </div>

      <!-- Controles del Carrusel (Flechas + Dots) - Solo Móvil -->
      <div class="flex md:hidden items-center justify-center gap-8 mt-6">
        <button 
          id="prev-event" 
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
          aria-label="Anterior"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div id="carousel-indicator" class="flex justify-center gap-3">
          {
            eventos.map((_, i) => {
              const activeClass = i === 0 ? 'bg-unicode w-6' : 'bg-zinc-800';
              return (
                <button 
                  class={`w-2 h-2 rounded-full transition-all duration-300 ${activeClass}`}
                  aria-label={`Ir al evento ${i + 1}`}
                  data-index={i}
                />
              );
            })
          }
        </div>

        <button 
          id="next-event" 
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
          aria-label="Siguiente"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- ==========================================
         VISTA PC (LISTA VERTICAL DETALLADA)
         ========================================== -->
    <div class="hidden lg:flex flex-col gap-16">
      {
        eventos.map((evento, index) => (
          <article 
            class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out relative w-full rounded-3xl overflow-hidden border border-zinc-800/50 group hover:border-unicode/30"
            style={`transition-delay: ${index * 150}ms;`}
          >
            <!-- Fondo con imagen -->
            <div class="absolute inset-0">
              <img
                src={evento.imagenFondo}
                alt=""
                class="w-full h-full object-cover opacity-30 group-hover:opacity-40 transition-opacity duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/70 to-black/50" />
            </div>

            <!-- Contenido del evento -->
            <div class="relative z-10 flex items-center gap-12 p-10">
              {/* Tarjeta del ponente */}
              <div class="shrink-0 w-64">
                <div class="relative rounded-2xl overflow-hidden border-2 border-unicode/40 shadow-unicode group-hover:shadow-unicode-lg transition-all duration-500">
                  <img
                    src={evento.imagenPonente}
                    alt={evento.ponente}
                    class="w-full aspect-[3/4] object-cover"
                  />
                  {/* Overlay inferior con info del ponente */}
                  <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/90 via-black/60 to-transparent p-4">
                    <div class="flex items-center gap-2 mb-1">
                      <svg class="w-3 h-3 text-unicode" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                      </svg>
                      <span class="text-zinc-400 text-[10px] uppercase tracking-widest font-medium">UNICODE</span>
                    </div>
                    <p class="text-white font-bold text-sm leading-tight">{evento.ponente}</p>
                    <div class="flex items-center gap-3 mt-2 text-[10px] text-zinc-400">
                      <span class="flex items-center gap-1">
                        <svg class="w-3 h-3 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                          <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        {evento.fecha}
                      </span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Información del evento */}
              <div class="flex-1 flex flex-col gap-4">
                <div>
                  <h3 class="text-4xl font-extrabold text-white">
                    {evento.ponente.split(" ")[0]}{" "}
                    <span class="text-unicode">{evento.ponente.split(" ").slice(1).join(" ")}</span>
                  </h3>
                  <p class="text-xl text-gray-300 font-medium mt-1 italic">
                    {evento.tema}
                  </p>
                </div>

                <div>
                  <h4 class="text-unicode font-bold text-lg mb-1">Descripción del evento:</h4>
                  <p class="text-gray-400 text-base leading-relaxed max-w-2xl">
                    {evento.descripcion}
                  </p>
                </div>

                {/* Datos del evento */}
                <div class="flex flex-wrap gap-4 text-sm text-gray-300 mt-2">
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    {evento.fecha}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                    </svg>
                    {evento.hora}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
                    </svg>
                    {evento.lugar}
                  </span>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- Modal (Solo para Mobile/Tablet) -->
  <div id="event-modal" class="fixed inset-0 z-100 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-300 bg-black/95 backdrop-blur-sm">
    <div class="relative w-full max-w-2xl bg-[#0a0a0a] border border-zinc-800 rounded-[32px] overflow-hidden shadow-2xl transition-transform duration-300 scale-95 flex flex-col max-h-[90vh]">
      <button id="close-modal" class="absolute top-6 right-6 z-50 p-2 bg-black/50 text-white rounded-full hover:bg-unicode transition-all">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="overflow-y-auto w-full scrollbar-v-hide">
        <div id="modal-body"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-v-hide::-webkit-scrollbar { width: 4px; }
  .scrollbar-v-hide::-webkit-scrollbar-thumb { background: #75d32d30; border-radius: 10px; }
  
  #event-modal.active { opacity: 1; pointer-events: auto; }
  #event-modal.active > div { transform: scale(1); }

  @media (max-width: 767px) {
    #events-scroll-container { padding-left: 6vw; padding-right: 6vw; }
    article { margin-right: 4vw; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Lógica Carrusel (Mobile/Tablet) ---
    const container = document.getElementById("events-scroll-container");
    const dots = document.querySelectorAll("#carousel-indicator button");
    const prevBtn = document.getElementById("prev-event");
    const nextBtn = document.getElementById("next-event");

    if (container) {
      const scrollStep = () => container.clientWidth;

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener("click", () => {
          container.scrollLeft -= scrollStep();
        });
        nextBtn.addEventListener("click", () => {
          container.scrollLeft += scrollStep();
        });
      }

      container.addEventListener("scroll", () => {
        const scrollIndex = Math.round(container.scrollLeft / container.clientWidth);
        dots.forEach((dot, i) => {
          if (i === scrollIndex) {
            dot.classList.add("bg-unicode", "w-6");
            dot.classList.remove("bg-zinc-800");
          } else {
            dot.classList.remove("bg-unicode", "w-6");
            dot.classList.add("bg-zinc-800");
          }
        });
      });
      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = parseInt(dot.getAttribute("data-index") || "0");
          container.scrollLeft = index * container.clientWidth;
        });
      });
    }

    // --- Lógica Modal ---
    const modal = document.getElementById("event-modal");
    const modalBody = document.getElementById("modal-body");
    const closeModal = document.getElementById("close-modal");
    const openBtns = document.querySelectorAll(".open-modal-btn");

    const getModalContent = (evento: any) => `
      <div class="relative h-64 md:h-80 overflow-hidden">
        <img src="${evento.imagenFondo}" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/60 to-transparent"></div>
        <div class="absolute bottom-8 left-8 right-8 text-left">
          <p class="text-unicode font-bold text-xs uppercase tracking-widest mb-2">Próximo Evento</p>
          <h2 class="text-2xl md:text-5xl font-black text-white leading-tight uppercase">${evento.tema.split('"').join('')}</h2>
        </div>
      </div>
      <div class="p-8 md:p-12 text-left">
        <div class="flex flex-col md:flex-row gap-8">
          <div class="shrink-0 flex flex-col items-center md:items-start">
             <div class="w-32 h-32 md:w-40 md:h-40 rounded-3xl overflow-hidden border-2 border-unicode shadow-unicode/20">
                <img src="${evento.imagenPonente}" class="w-full h-full object-cover">
             </div>
             <p class="text-unicode font-black text-lg mt-4 text-center md:text-left">${evento.ponente}</p>
          </div>
          <div class="flex-1 space-y-6">
            <div>
              <h4 class="text-white font-bold text-xl mb-3 border-l-4 border-unicode pl-4">Descripción</h4>
              <p class="text-zinc-400 leading-relaxed text-base">${evento.descripcion}</p>
            </div>
            <div class="grid grid-cols-1 gap-4 bg-zinc-900/40 p-5 rounded-2xl border border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="text-unicode"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /></svg></div>
                <p class="text-white font-bold text-sm">${evento.fecha} - ${evento.hora}</p>
              </div>
              <div class="flex items-center gap-3">
                <div class="text-unicode"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
                <p class="text-white font-bold text-sm">${evento.lugar}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    `;

    openBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const article = btn.closest("article");
        if (article) {
          const data = JSON.parse(article.getAttribute("data-evento-json") || "{}");
          if (modalBody) {
            modalBody.innerHTML = getModalContent(data);
            modal?.classList.add("active");
            document.body.style.overflow = "hidden";
          }
        }
      });
    });

    const close = () => { modal?.classList.remove("active"); document.body.style.overflow = "auto"; };
    closeModal?.addEventListener("click", close);
    modal?.addEventListener("click", (e) => { if (e.target === modal) close(); });

    // --- Revelado de scroll ---
    const obs = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.remove("opacity-0", "translate-y-8", "translate-y-12");
          e.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll(".scroll-reveal").forEach((el) => obs.observe(el));
  });
</script>
