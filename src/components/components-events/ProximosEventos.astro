---
/**
 * ProximosEventos.astro
 * Sección de Próximos Eventos con visualización responsiva diferenciada:
 * - Mobile/Tablet: Carrusel interactivo con tarjetas compactas y modales.
 * - PC (Desktop): Lista vertical de tarjetas expandidas (formato original).
 */

import { proximosEventos as eventos } from "../../data/events";
---

<section id="proximos-eventos" class="w-full py-20 md:py-28 bg-[#050505] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <h2
      class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out text-4xl md:text-6xl font-extrabold text-center mb-16 uppercase tracking-tight"
    >
      PRÓXIMOS <span class="text-unicode">EVENTOS</span>
    </h2>

    <!-- ==========================================
         VISTA MÓVIL Y TABLET (CARRUSEL)
         ========================================== -->
    <div class="lg:hidden relative group/carousel">
      <!-- Contenedor Responsive (Flex carrusel en móvil, Grid en tablet/desktop) -->
      <div 
        id="events-scroll-container"
        class="flex md:grid md:grid-cols-2 gap-6 overflow-x-auto md:overflow-x-visible pb-4 md:pb-0 snap-x snap-mandatory scrollbar-hide scroll-smooth"
      >
        {
          eventos.map((evento, index) => {
            const cleanTema = evento.tema.split('"').join('');
            return (
              <article 
                class="scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out flex-none w-[88vw] md:w-auto relative rounded-3xl overflow-hidden border border-zinc-800/50 group bg-zinc-900/20 snap-center hover:border-unicode/30"
                style={`transition-delay: ${index * 100}ms;`}
                data-evento-json={JSON.stringify(evento)}
              >
                <div class="absolute inset-0 z-0">
                  <img src={evento.imagenFondo} alt="" class="w-full h-full object-cover opacity-20 group-hover:opacity-30 transition-opacity duration-500" />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/80 to-transparent" />
                </div>

                <div class="relative z-10 p-6 md:p-8 flex flex-col h-full">
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-unicode shadow-unicode/20">
                      <img src={evento.imagenPonente} alt={evento.ponente} class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-white font-bold text-base truncate">{evento.ponente}</h3>
                    </div>
                  </div>

                  <h4 class="text-xl font-black text-white leading-tight mb-3 line-clamp-2 min-h-14 group-hover:text-unicode transition-colors">
                    {cleanTema}
                  </h4>

                  <p class="text-zinc-400 text-sm mb-6 line-clamp-3">
                    {evento.descripcion}
                  </p>

                  <div class="mt-auto space-y-2 mb-6">
                    <div class="flex items-center gap-2 text-xs text-zinc-400 font-medium">
                      <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                        <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" />
                      </svg>
                      {evento.fecha} • {evento.hora}
                    </div>
                    <div class="flex items-center gap-2 text-xs text-zinc-400 font-medium whitespace-nowrap overflow-hidden">
                      <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
                      </svg>
                      <span class="truncate">{evento.lugar}</span>
                    </div>
                  </div>

                  <a 
                    href={evento.inscripcionUrl && evento.inscripcionUrl !== "#" ? evento.inscripcionUrl : "https://www.linkedin.com/company/unicode-usm/"}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block text-center w-full py-3 bg-unicode/10 hover:bg-unicode text-unicode hover:text-black font-bold text-xs uppercase tracking-widest rounded-xl border border-unicode/30 transition-all duration-300"
                  >
                    Ver más
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>

      <!-- Controles del Carrusel (Flechas + Dots) - Solo Móvil -->
      <div class="flex md:hidden items-center justify-center gap-8 mt-6">
        <button 
          id="prev-event" 
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
          aria-label="Anterior"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <div id="carousel-indicator" class="flex justify-center gap-3">
          {
            eventos.map((_, i) => {
              const activeClass = i === 0 ? 'bg-unicode w-6' : 'bg-zinc-800';
              return (
                <button 
                  class={`w-2 h-2 rounded-full transition-all duration-300 ${activeClass}`}
                  aria-label={`Ir al evento ${i + 1}`}
                  data-index={i}
                />
              );
            })
          }
        </div>

        <button 
          id="next-event" 
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
          aria-label="Siguiente"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- ==========================================
         VISTA PC (LISTA VERTICAL DETALLADA)
         ========================================== -->
    <div class="hidden lg:flex flex-col gap-16">
      {
        eventos.map((evento, index) => (
          <article 
            class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out relative w-full rounded-3xl overflow-hidden border border-zinc-800/50 group hover:border-unicode/30"
            style={`transition-delay: ${index * 150}ms;`}
          >
            <!-- Fondo con imagen -->
            <div class="absolute inset-0">
              <img
                src={evento.imagenFondo}
                alt=""
                class="w-full h-full object-cover opacity-30 group-hover:opacity-40 transition-opacity duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/70 to-black/50" />
            </div>

            <!-- Contenido del evento -->
            <div class="relative z-10 flex items-center gap-12 p-10">
              {/* Tarjeta del ponente */}
              <div class="shrink-0 w-64">
                <div class="relative rounded-2xl overflow-hidden border-2 border-unicode/40 shadow-unicode group-hover:shadow-unicode-lg transition-all duration-500">
                  <img
                    src={evento.imagenPonente}
                    alt={evento.ponente}
                    class="w-full aspect-square object-cover"
                  />
                </div>
              </div>

              {/* Información del evento */}
              <div class="flex-1 flex flex-col gap-4">
                <div>
                  <h3 class="text-4xl font-extrabold text-white">
                    {evento.ponente.split(" ")[0]}{" "}
                    <span class="text-unicode">{evento.ponente.split(" ").slice(1).join(" ")}</span>
                  </h3>
                  <p class="text-xl text-gray-300 font-medium mt-1 italic">
                    {evento.tema}
                  </p>
                </div>

                <div>
                  <h4 class="text-unicode font-bold text-lg mb-1">Descripción del evento:</h4>
                  <p class="text-gray-400 text-base leading-relaxed max-w-2xl">
                    {evento.descripcion}
                  </p>
                </div>

                {/* Datos del evento */}
                <div class="flex flex-wrap items-center gap-4 text-sm text-gray-300 mt-2">
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    {evento.fecha}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                    </svg>
                    {evento.hora}
                  </span>
                  <span class="flex items-center gap-2 bg-zinc-900/80 px-4 py-2 rounded-full border border-zinc-800">
                    <svg class="w-4 h-4 text-unicode" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" />
                    </svg>
                    {evento.lugar}
                  </span>
                  
                  {/* Botón Ver más PC */}
                  <a 
                    href={evento.inscripcionUrl && evento.inscripcionUrl !== "#" ? evento.inscripcionUrl : "https://www.linkedin.com/company/unicode-usm/"}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block py-2 px-6 ml-2 bg-unicode/10 hover:bg-unicode text-unicode hover:text-black font-bold text-xs uppercase tracking-widest rounded-full border border-unicode/30 transition-all duration-300"
                  >
                    Ver más
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>


</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-v-hide::-webkit-scrollbar { width: 4px; }
  .scrollbar-v-hide::-webkit-scrollbar-thumb { background: #75d32d30; border-radius: 10px; }
  


  @media (max-width: 767px) {
    #events-scroll-container { padding-left: 6vw; padding-right: 6vw; }
    article { margin-right: 4vw; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Lógica Carrusel (Mobile/Tablet) ---
    const container = document.getElementById("events-scroll-container");
    const dots = document.querySelectorAll("#carousel-indicator button");
    const prevBtn = document.getElementById("prev-event");
    const nextBtn = document.getElementById("next-event");

    if (container) {
      const scrollStep = () => container.clientWidth;

      if (prevBtn && nextBtn) {
        prevBtn.addEventListener("click", () => {
          container.scrollLeft -= scrollStep();
        });
        nextBtn.addEventListener("click", () => {
          container.scrollLeft += scrollStep();
        });
      }

      container.addEventListener("scroll", () => {
        const scrollIndex = Math.round(container.scrollLeft / container.clientWidth);
        dots.forEach((dot, i) => {
          if (i === scrollIndex) {
            dot.classList.add("bg-unicode", "w-6");
            dot.classList.remove("bg-zinc-800");
          } else {
            dot.classList.remove("bg-unicode", "w-6");
            dot.classList.add("bg-zinc-800");
          }
        });
      });
      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = parseInt(dot.getAttribute("data-index") || "0");
          container.scrollLeft = index * container.clientWidth;
        });
      });
    }


    // --- Revelado de scroll ---
    const obs = new IntersectionObserver((es) => {
      es.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.remove("opacity-0", "translate-y-8", "translate-y-12");
          e.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll(".scroll-reveal").forEach((el) => obs.observe(el));
  });
</script>
