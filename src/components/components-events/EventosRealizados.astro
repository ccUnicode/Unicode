---
/**
 * EventosRealizados.astro
 * Sección de galería de Eventos Realizados con visualización responsiva:
 * - Mobile/Tablet: Carrusel horizontal interactivo.
 * - PC (Desktop): Grid tradicional de 3 columnas (diseño original).
 */

interface EventoRealizado {
    titulo: string;
    descripcion: string;
    fecha: string;
    asistentes: number;
    categoria: string;
    imagen: string;
    ponente: string;
    lugar: string;
    highlights: string[];
    link?: string;
}

const eventosRealizados: EventoRealizado[] = [
    {
        titulo: "Hackatón UNICODE 2025",
        descripcion:
            "48 horas de innovación donde equipos multidisciplinarios desarrollaron soluciones tecnológicas para problemas reales de la comunidad universitaria.",
        fecha: "15 Oct 2025",
        asistentes: 120,
        categoria: "Hackathon",
        imagen: "/evento_unicode_1.png",
        ponente: "Equipo UNICODE",
        lugar: "Auditorio FIIS",
        highlights: ["1er puesto: EcoTrack App", "12 equipos participantes"],
    },
    {
        titulo: "Workshop: Git & GitHub",
        descripcion:
            "Taller práctico de control de versiones donde los asistentes aprendieron desde los fundamentos hasta flujos de trabajo colaborativos avanzados.",
        fecha: "28 Sep 2025",
        asistentes: 85,
        categoria: "Workshop",
        imagen: "/evento_unicode_2.png",
        ponente: "Carlos Mendoza",
        lugar: "Lab. Cómputo FIIS",
        highlights: ["Certificados digitales", "Ejercicios hands-on"],
    },
    {
        titulo: "Charla: IA en la Industria",
        descripcion:
            "Un recorrido por las aplicaciones reales de la inteligencia artificial en sectores como salud, finanzas y manufactura, con casos de éxito peruanos.",
        fecha: "10 Sep 2025",
        asistentes: 200,
        categoria: "Charla",
        imagen: "/evento_unicode_1.png",
        ponente: "Dra. Ana Torres",
        lugar: "Auditorio FIIS",
        highlights: ["Transmisión en vivo", "+500 views online"],
    },
    {
        titulo: "Code Night: Algoritmos",
        descripcion:
            "Una noche dedicada a resolver desafíos algorítmicos en equipos, con problemas de distintos niveles de dificultad y premios para los ganadores.",
        fecha: "20 Ago 2025",
        asistentes: 65,
        categoria: "Competencia",
        imagen: "/evento_unicode_2.png",
        ponente: "Club UNICODE",
        lugar: "Lab. Cómputo FIIS",
        highlights: ["3 niveles de dificultad", "Premios especiales"],
    },
    {
        titulo: "Panel: Mujeres en Tech",
        descripcion:
            "Un panel con ingenieras líderes de empresas tech peruanas compartiendo sus experiencias, desafíos y consejos para nuevas generaciones.",
        fecha: "05 Ago 2025",
        asistentes: 150,
        categoria: "Panel",
        imagen: "/evento_unicode_1.png",
        ponente: "4 Panelistas",
        lugar: "Auditorio FIIS",
        highlights: ["4 panelistas invitadas", "Q&A abierto"],
    },
    {
        titulo: "Intro a React & Next.js",
        descripcion:
            "Workshop intensivo de frontend moderno: desde componentes React hasta aplicaciones full-stack con Next.js y despliegue en Vercel.",
        fecha: "18 Jul 2025",
        asistentes: 90,
        categoria: "Workshop",
        imagen: "/evento_unicode_2.png",
        ponente: "Luis Ramírez",
        lugar: "Lab. Cómputo FIIS",
        highlights: ["Proyecto desplegado", "Recursos gratuitos"],
    },
    {
        titulo: "Taller: Docker & Kubernetes",
        descripcion:
            "Aprendimos a contenerizar aplicaciones y orquestar servicios usando las herramientas líderes del mercado en infraestructura moderna.",
        fecha: "30 Jun 2025",
        asistentes: 75,
        categoria: "Workshop",
        imagen: "/evento_unicode_1.png",
        ponente: "Ing. Marco Ruiz",
        lugar: "Lab. Cómputo FIIS",
        highlights: ["Nivel Intermedio", "Práctica en AWS"],
    },
    {
        titulo: "Conferencia: Ciberseguridad",
        descripcion:
            "Un análisis profundo sobre las amenazas actuales y cómo proteger infraestructuras críticas en la era de la transformación digital.",
        fecha: "12 Jun 2025",
        asistentes: 180,
        categoria: "Charla",
        imagen: "/evento_unicode_2.png",
        ponente: "Dra. Sofía Valery",
        lugar: "Auditorio FIIS",
        highlights: ["Networking", "Demo en vivo"],
    },
    {
        titulo: "Bootcamp: Python & Data Science",
        descripcion:
            "Un programa intensivo donde exploramos el análisis de datos, visualización y modelado predictivo utilizando las librerías más potentes del ecosistema Python.",
        fecha: "25 May 2025",
        asistentes: 110,
        categoria: "Workshop",
        imagen: "/evento_unicode_1.png",
        ponente: "Ing. Roberto Salas",
        lugar: "Lab. Cómputo FIIS",
        highlights: ["Certificación Académica", "Proyectos de ML"],
    },
    {
        titulo: "Tech Talk: Cloud Architecture",
        descripcion:
            "Exploramos las mejores prácticas para diseñar arquitecturas escalables y resilientes en la nube, comparando AWS, Azure y Google Cloud.",
        fecha: "10 May 2025",
        asistentes: 140,
        categoria: "Charla",
        imagen: "/evento_unicode_2.png",
        ponente: "Ing. Elena Gomez",
        lugar: "Auditorio FIIS",
        highlights: ["Demo Arquitectura", "Q&A"],
    },
];

const totalEventos = eventosRealizados.length;
const totalAsistentes = eventosRealizados.reduce(
    (sum, e) => sum + e.asistentes,
    0,
);
const categorias = [...new Set(eventosRealizados.map((e) => e.categoria))];

const categoriaBadge: Record<string, string> = {
    Hackathon:
        "bg-purple-900/40 text-purple-200 border-purple-500/50 backdrop-blur-md",
    Workshop:
        "bg-blue-900/40 text-blue-200 border-blue-500/50 backdrop-blur-md",
    Charla: "bg-green-900/40 text-unicode-light border-unicode/50 backdrop-blur-md",
    Competencia:
        "bg-amber-900/40 text-amber-200 border-amber-500/50 backdrop-blur-md",
    Panel: "bg-pink-900/40 text-pink-200 border-pink-500/50 backdrop-blur-md",
};

// Fragmentar eventos en grupos de 6 para la vista de Tablet y PC
const chunks6 = [];
for (let i = 0; i < eventosRealizados.length; i += 6) {
    chunks6.push(eventosRealizados.slice(i, i + 6));
}
---

<section
    id="eventos-realizados"
    class="w-full py-20 md:py-28 bg-[#050505] relative overflow-hidden"
>
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-unicode/3 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <!-- Header -->
        <div
            class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out text-center mb-16"
        >
            <div
                class="inline-flex items-center gap-2 bg-unicode/10 border border-unicode/20 rounded-full px-4 py-1.5 mb-6"
            >
                <span class="w-2 h-2 bg-unicode rounded-full animate-pulse"
                ></span>
                <span
                    class="text-unicode text-xs font-semibold uppercase tracking-widest"
                    >Historial</span
                >
            </div>
            <h2
                class="text-4xl md:text-6xl font-extrabold uppercase tracking-tight mb-4"
            >
                EVENTOS <span class="text-unicode">REALIZADOS</span>
            </h2>
            <p
                class="text-gray-400 text-base md:text-lg max-w-2xl mx-auto leading-relaxed"
            >
                Revive los mejores momentos de nuestros eventos pasados. Cada
                encuentro es una oportunidad de aprender y conectar.
            </p>
        </div>

        <!-- Estadísticas -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-20 px-2">
            {
                [
                    { label: "Eventos", val: totalEventos, delay: 100 },
                    { label: "Asistentes", val: totalAsistentes, delay: 200 },
                    { label: "Categorías", val: categorias.length, delay: 300 },
                    {
                        label: "Gratuitos",
                        val: "100%",
                        delay: 400,
                        noAnim: true,
                    },
                ].map((stat) => (
                    <div
                        class="scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out text-center bg-zinc-900/50 border border-zinc-800 rounded-2xl p-5 hover:border-unicode/30"
                        style={`transition-delay: ${stat.delay}ms;`}
                    >
                        <p
                            class={`text-3xl md:text-4xl font-extrabold ${stat.noAnim ? "text-white" : "text-unicode stat-number"} mb-1`}
                            data-target={
                                typeof stat.val === "number" ? stat.val : 0
                            }
                        >
                            {stat.noAnim ? stat.val : "0"}
                        </p>
                        <p class="text-gray-400 text-xs md:text-sm uppercase tracking-wider font-medium">
                            {stat.label}
                        </p>
                    </div>
                ))
            }
        </div>

        <!-- Buscador -->
        <div
            class="flex justify-center mb-10 scroll-reveal opacity-0 translate-y-8 transition-all duration-700 ease-out"
        >
            <div class="relative w-full max-w-xl group">
                <span
                    class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-unicode transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="11" cy="11" r="8"></circle><path
                            d="m21 21-4.3-4.3"></path></svg
                    >
                </span>
                <input
                    type="text"
                    id="event-search"
                    placeholder="Buscar eventos por título, categoría o resumen..."
                    class="w-full bg-zinc-900/50 border border-zinc-800 rounded-full py-3 px-12 focus:outline-none focus:border-unicode transition-all placeholder:text-zinc-600 focus:ring-1 focus:ring-unicode/20 text-white"
                />
            </div>
        </div>

        <div id="no-events-results" class="hidden text-center py-10">
            <p class="text-zinc-500 text-lg font-medium">
                No se encontraron eventos que coincidan con tu búsqueda.
            </p>
        </div>

        <!-- ==========================================
             VISTA MÓVIL (1 CARD POR PÁGINA)
             ========================================== -->
        <div class="md:hidden relative group/past-carousel-mobile">
            <div
                id="past-events-scroll-mobile"
                class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide scroll-smooth px-2"
            >
                {
                    eventosRealizados.map((evento, index) => (
                        <article class="event-item scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out flex-none w-[85vw] relative rounded-3xl overflow-hidden border border-zinc-800/50 bg-zinc-900/30 snap-center">
                            <div class="relative h-44 overflow-hidden">
                                <img
                                    src={evento.imagen}
                                    alt={evento.titulo}
                                    class="w-full h-full object-cover"
                                />
                                <div class="absolute inset-0 bg-linear-to-t from-zinc-900 to-transparent" />
                                <div class="absolute top-4 left-4">
                                    <span
                                        class={`inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold uppercase border ${categoriaBadge[evento.categoria]}`}
                                    >
                                        {evento.categoria}
                                    </span>
                                </div>
                            </div>
                            <div class="p-6">
                                <h3 class="text-lg font-bold text-white mb-2 line-clamp-1">
                                    {evento.titulo}
                                </h3>
                                <div class="flex items-center gap-3 text-[10px] text-zinc-500 mb-3">
                                    <span class="flex items-center gap-1">
                                        <svg
                                            class="w-3 h-3 text-unicode"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <>
                                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                                                <circle cx="12" cy="7" r="4" />
                                            </>
                                        </svg>
                                        {evento.ponente}
                                    </span>
                                    <span class="flex items-center gap-1">
                                        <svg
                                            class="w-3 h-3 text-unicode"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <>
                                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                                                <circle cx="12" cy="10" r="3" />
                                            </>
                                        </svg>
                                        {evento.lugar}
                                    </span>
                                </div>
                                <p class="text-zinc-400 text-xs leading-relaxed line-clamp-2 mb-4">
                                    {evento.descripcion}
                                </p>
                                <a
                                    href={
                                        evento.link ||
                                        "https://www.linkedin.com/company/unicode-usm/"
                                    }
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="block text-center w-full py-2.5 bg-unicode/10 hover:bg-unicode text-unicode hover:text-black font-bold text-xs uppercase tracking-widest rounded-xl border border-unicode/30 transition-all duration-300"
                                >
                                    Ver más
                                </a>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="flex items-center justify-center gap-8 mt-6">
                <!-- Flecha Izquierda -->
                <button
                    id="prev-past-event-mobile"
                    class="w-12 h-12 flex items-center justify-center bg-zinc-900/50 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
                    aria-label="Anterior"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>

                <!-- Indicadores -->
                <div
                    id="past-carousel-indicator-mobile"
                    class="flex justify-center items-center gap-2"
                >
                    {
                        eventosRealizados.map((_, i) => (
                            <button
                                class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-unicode w-6" : "bg-zinc-800 w-2"}`}
                                data-index={i}
                                aria-label={`Ir al evento ${i + 1}`}
                            />
                        ))
                    }
                </div>

                <!-- Flecha Derecha -->
                <button
                    id="next-past-event-mobile"
                    class="w-12 h-12 flex items-center justify-center bg-zinc-900/50 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg"
                    aria-label="Siguiente"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 5l7 7-7 7"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- ==========================================
             VISTA TABLET Y PC (6 CARDS POR PÁGINA)
             ========================================== -->
        <div class="hidden md:block relative group/past-carousel-desktop">
            <div
                id="past-events-scroll-desktop"
                class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide scroll-smooth pb-4 px-2"
            >
                {
                    chunks6.map((chunk, chunkIndex) => (
                        <div class="flex-none w-full grid grid-cols-2 lg:grid-cols-3 gap-6 snap-center">
                            {chunk.map((evento, index) => (
                                <article
                                    class="event-item scroll-reveal opacity-0 translate-y-12 transition-all duration-700 ease-out relative rounded-3xl overflow-hidden border border-zinc-800/50 bg-zinc-900/30 hover:border-unicode/30 hover:-translate-y-2 group"
                                    style={`transition-delay: ${(index % 3) * 100}ms`}
                                >
                                    <div class="relative h-48 overflow-hidden">
                                        <img
                                            src={evento.imagen}
                                            alt={evento.titulo}
                                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                        />
                                        <div class="absolute inset-0 bg-linear-to-t from-zinc-900 via-zinc-900/40 to-transparent" />
                                        <div class="absolute top-4 left-4">
                                            <span
                                                class={`inline-flex items-center px-3 py-1 rounded-full text-[11px] font-semibold uppercase tracking-wider border ${categoriaBadge[evento.categoria]}`}
                                            >
                                                {evento.categoria}
                                            </span>
                                        </div>
                                        <div class="absolute bottom-4 right-4">
                                            <span class="inline-flex items-center gap-1.5 bg-black/60 backdrop-blur-sm px-3 py-1.5 rounded-full text-[10px] text-gray-300 border border-zinc-700/50">
                                                {evento.fecha}
                                            </span>
                                        </div>
                                    </div>
                                    <div class="p-6">
                                        <h3 class="text-xl font-bold text-white mb-3 group-hover:text-unicode transition-colors">
                                            {evento.titulo}
                                        </h3>
                                        <div class="flex items-center gap-4 text-xs text-zinc-500 mb-4">
                                            <span class="flex items-center gap-1.5">
                                                <svg
                                                    class="w-4 h-4 text-unicode/70"
                                                    fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                                                    <circle
                                                        cx="12"
                                                        cy="7"
                                                        r="4"
                                                    />
                                                </svg>
                                                {evento.ponente}
                                            </span>
                                            <span class="flex items-center gap-1.5">
                                                <svg
                                                    class="w-4 h-4 text-unicode/70"
                                                    fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                >
                                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                                                    <circle
                                                        cx="12"
                                                        cy="10"
                                                        r="3"
                                                    />
                                                </svg>
                                                {evento.lugar}
                                            </span>
                                        </div>
                                        <p class="text-zinc-400 text-sm leading-relaxed line-clamp-3 mb-4 flex-1">
                                            {evento.descripcion}
                                        </p>
                                        <div class="flex flex-wrap items-center gap-2 mt-auto">
                                            {evento.highlights.map((h) => (
                                                <span class="text-[10px] text-unicode/70 bg-unicode/5 border border-unicode/10 rounded-full px-2 py-0.5">
                                                    #{h.split(" ")[0]}
                                                </span>
                                            ))}
                                            <a
                                                href={
                                                    evento.link ||
                                                    "https://www.linkedin.com/company/unicode-usm/"
                                                }
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="inline-block ml-auto py-1.5 px-4 bg-unicode/10 hover:bg-unicode text-unicode hover:text-black font-bold text-[10px] uppercase tracking-widest rounded-xl border border-unicode/30 transition-all duration-300"
                                            >
                                                Ver más
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    ))
                }
            </div>

            <div class="flex items-center justify-center gap-8 mt-10">
                <button
                    id="prev-past-event-desktop"
                    class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full hover:border-unicode transition-all shadow-lg group/btn"
                >
                    <svg
                        class="w-6 h-6 group-hover/btn:-translate-x-1 transition-transform"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>

                <div
                    id="past-carousel-indicator-desktop"
                    class="flex justify-center items-center gap-3"
                >
                    {
                        chunks6.map((_, i) => (
                            <button
                                class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-unicode w-10" : "bg-zinc-800 w-3"}`}
                                data-index={i}
                                aria-label={`Ir a la página ${i + 1}`}
                            />
                        ))
                    }
                </div>

                <button
                    id="next-past-event-desktop"
                    class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full hover:border-unicode transition-all shadow-lg group/btn"
                >
                    <svg
                        class="w-6 h-6 group-hover/btn:translate-x-1 transition-transform"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 5l7 7-7 7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <style>
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // --- Estadísticas ---
            const statsObs = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target
                                .querySelectorAll(".stat-number")
                                .forEach((el) => {
                                    const target = parseInt(
                                        el.getAttribute("data-target") || "0",
                                    );
                                    if (target === 0) return;
                                    let curr = 0;
                                    const inc = Math.ceil(target / 50);
                                    const timer = setInterval(() => {
                                        curr += inc;
                                        if (curr >= target) {
                                            curr = target;
                                            clearInterval(timer);
                                        }
                                        el.textContent = curr.toLocaleString();
                                    }, 30);
                                });
                            statsObs.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.3 },
            );

            const section = document.querySelector("#eventos-realizados");
            if (section) statsObs.observe(section);

            // --- Carruseles (Mobile y Desktop/Tablet) ---
            const carousels = [
                {
                    id: "past-events-scroll-mobile",
                    dotsId: "past-carousel-indicator-mobile",
                    prevId: "prev-past-event-mobile",
                    nextId: "next-past-event-mobile",
                },
                {
                    id: "past-events-scroll-desktop",
                    dotsId: "past-carousel-indicator-desktop",
                    prevId: "prev-past-event-desktop",
                    nextId: "next-past-event-desktop",
                },
            ];

            carousels.forEach((cfg) => {
                const container = document.getElementById(cfg.id);
                const dots = document.querySelectorAll(`#${cfg.dotsId} button`);
                const prevBtn = document.getElementById(cfg.prevId);
                const nextBtn = document.getElementById(cfg.nextId);

                if (container) {
                    const scrollStep = () => container.clientWidth;

                    if (prevBtn && nextBtn) {
                        prevBtn.addEventListener("click", () => {
                            container.scrollLeft -= scrollStep();
                        });
                        nextBtn.addEventListener("click", () => {
                            container.scrollLeft += scrollStep();
                        });
                    }

                    container.addEventListener("scroll", () => {
                        const idx = Math.round(
                            container.scrollLeft / container.clientWidth,
                        );
                        dots.forEach((dot, i) => {
                            const isMobile = cfg.id.includes("mobile");
                            if (i === idx) {
                                dot.classList.add("bg-unicode");
                                dot.classList.remove("bg-zinc-800");
                                dot.classList.add(isMobile ? "w-6" : "w-10");
                                dot.classList.remove(isMobile ? "w-2" : "w-3");
                            } else {
                                dot.classList.remove("bg-unicode");
                                dot.classList.add("bg-zinc-800");
                                dot.classList.remove(isMobile ? "w-6" : "w-10");
                                dot.classList.add(isMobile ? "w-2" : "w-3");
                            }
                        });
                    });

                    dots.forEach((dot) => {
                        dot.addEventListener("click", () => {
                            const i = parseInt(
                                dot.getAttribute("data-index") || "0",
                            );
                            container.scrollLeft = i * container.clientWidth;
                        });
                    });
                }
            });

            // --- Scroll Reveal ---
            const revealObs = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.remove(
                                "opacity-0",
                                "translate-y-12",
                            );
                            entry.target.classList.add(
                                "opacity-100",
                                "translate-y-0",
                            );
                        }
                    });
                },
                { threshold: 0.1 },
            );

            document
                .querySelectorAll(".scroll-reveal")
                .forEach((el) => revealObs.observe(el));

            // --- Búsqueda de Eventos ---
            const searchInput = document.getElementById(
                "event-search",
            ) as HTMLInputElement;
            const noResults = document.getElementById("no-events-results");
            const eventItems = document.querySelectorAll(".event-item");

            if (searchInput && eventItems.length > 0) {
                searchInput.addEventListener("input", () => {
                    const searchTerm = searchInput.value.toLowerCase().trim();
                    let visibleCount = 0;

                    eventItems.forEach((item) => {
                        const elem = item as HTMLElement;
                        // Búsqueda aproximada en todo el texto del article
                        const fullText = elem.textContent?.toLowerCase() || "";

                        if (fullText.includes(searchTerm)) {
                            elem.style.display = "";
                            visibleCount++;
                        } else {
                            elem.style.display = "none";
                        }
                    });

                    if (visibleCount === 0) {
                        noResults?.classList.remove("hidden");
                    } else {
                        noResults?.classList.add("hidden");
                    }

                    // Ocultar flechas e indicadores en móvil cuando se busca
                    const indicatorContainer = document.getElementById(
                        "past-carousel-indicator",
                    )?.parentElement;
                    if (indicatorContainer) {
                        indicatorContainer.style.display =
                            searchTerm.length > 0 ? "none" : "";
                    }
                });
            }
        });
    </script>
</section>
