---
/**
 * HeroEventos.astro
 * Sección Hero para la página de Eventos.
 * Diseño: "Neural Mesh Plexus" - Fondo de red neuronal con nodos conectados y malla hexagonal.
 * Estética: Tech de alto impacto, minimalista en el centro y compleja en los bordes.
 */
---

<section
    id="hero-eventos"
    class="relative w-full min-h-svh flex items-center justify-center overflow-hidden bg-[#050505] font-sans"
>
    <!-- 1. Capa de Fondo: Patrón Hexagonal -->
    <div
        class="absolute inset-0 z-0 opacity-20 pointer-events-none"
        style="background-image: radial-gradient(circle at 2px 2px, rgba(117,211,45,0.1) 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>
    <div
        class="absolute inset-0 z-0 opacity-10 pointer-events-none"
        style="background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI1MiIgaGVpZ2h0PSI2MCI+PHBhdGggZD0iTTI2IDBMMDUyIDE1VjQ1TDI2IDYwTDAgNDVWMTVMMjYgMFoiIGZpbGw9Im5vbmUiIHN0cm9rZT0icmdiYSgxMTcsIDIxMSwgNDUsIDAuMikiIHN0cm9rZS13aWR0aD0iMSIvPjwvc3ZnPg=='); background-size: 52px 60px;"
    >
    </div>

    <!-- 2. Capa de Animación: Plexus (Nodos y Conexiones) -->
    <canvas id="hero-plexus" class="absolute inset-0 z-10 pointer-events-none"
    ></canvas>

    <!-- 3. Viñeta Radial para enfocar el centro -->
    <div
        class="absolute inset-0 z-20 pointer-events-none bg-[radial-gradient(circle_at_center,transparent_0%,rgba(5,5,5,0.4)_50%,#050505_100%)]"
    >
    </div>

    <!-- 4. Contenido Principal -->
    <div
        class="relative z-30 flex flex-col items-center text-center px-4 md:px-6 w-full max-w-5xl mx-auto"
    >
        <!-- Badge Superior -->
        <div
            class="reveal-item mb-8 flex items-center gap-2 px-5 py-1.5 rounded-full border border-unicode/30 bg-black/50 backdrop-blur-md shadow-[0_0_20px_rgba(117,211,45,0.1)]"
            style="animation-delay: 100ms;"
        >
            <span class="text-unicode font-bold text-sm">$</span>
            <span
                class="text-[10px] md:text-xs font-bold tracking-[0.2em] text-white uppercase mt-0.5"
            >
                Comunidad Unicode
            </span>
        </div>

        <!-- Título Principal -->
        <h1
            class="reveal-item flex flex-col items-center gap-0 font-black tracking-tight leading-[0.9] mb-8 uppercase select-none"
            style="animation-delay: 300ms;"
        >
            <span
                class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-white"
            >
                Eventos
            </span>
            <span
                class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-unicode drop-shadow-[0_0_30px_rgba(117,211,45,0.5)]"
            >
                UNICODE
            </span>
        </h1>

        <!-- Descripción -->
        <p
            class="reveal-item text-sm md:text-base lg:text-lg text-zinc-400 max-w-xl leading-relaxed font-medium mb-10 px-4"
            style="animation-delay: 500ms;"
        >
            Aprende, conecta y construye el futuro tecnológico junto a nuestra
            comunidad.
        </p>

        <!-- Botón Conoce más -->
        <div class="reveal-item" style="animation-delay: 700ms;">
            <a
                href="#proximos-eventos"
                class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-unicode text-black font-extrabold uppercase text-sm tracking-wider rounded-full hover:bg-[#8ff241] transition-all duration-300 shadow-[0_0_25px_rgba(117,211,45,0.4)] hover:shadow-[0_0_35px_rgba(117,211,45,0.6)]"
            >
                Conoce más
                <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="3"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap");

    #hero-eventos {
        font-family: "Inter", sans-serif;
    }

    .reveal-item {
        opacity: 0;
        transform: translateY(20px);
        animation: reveal 0.8s cubic-bezier(0.2, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    /**
     * Motor de Animación Plexus
     */
    document.addEventListener("DOMContentLoaded", () => {
        const canvas = document.getElementById(
            "hero-plexus",
        ) as HTMLCanvasElement;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        let width: number, height: number;
        let particles: Particle[] = [];
        const connectionDist = 160;
        const particleCount = Math.min(Math.floor(window.innerWidth / 12), 100);

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;

            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.vx = (Math.random() - 0.5) * 0.6;
                this.vy = (Math.random() - 0.5) * 0.6;
                this.size = Math.random() * 2 + 1;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;

                if (this.x < 0 || this.x > width) this.vx *= -1;
                if (this.y < 0 || this.y > height) this.vy *= -1;
            }

            draw() {
                if (!ctx) return;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = "rgba(117, 211, 45, 0.6)";
                ctx.fill();
            }
        }

        function resize() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            init();
        }

        function init() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
        }

        function drawLines() {
            if (!ctx) return;
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < connectionDist) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        // Cuanto más cerca, más opacidad
                        const opacity = 1 - dist / connectionDist;
                        ctx.strokeStyle = `rgba(117, 211, 45, ${opacity * 0.25})`;
                        ctx.lineWidth = 0.8;
                        ctx.stroke();
                    }
                }
            }
        }

        function animate() {
            if (!ctx) return;
            ctx.clearRect(0, 0, width, height);

            particles.forEach((p) => {
                p.update();
                p.draw();
            });

            drawLines();
            requestAnimationFrame(animate);
        }

        window.addEventListener("resize", resize);
        resize();
        animate();
    });
</script>
