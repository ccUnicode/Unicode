<div class="flex flex-col md:flex-row gap-4 items-center justify-center mb-6 w-full max-w-4xl">
  <div class="relative w-full max-w-xl group">
    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 group-focus-within:text-unicode transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    </span>
    <input 
      type="text" 
      placeholder="Buscar proyectos ..." 
      class="w-full bg-zinc-900/50 border border-zinc-800 rounded-full py-3 px-12 focus:outline-none focus:border-unicode transition-all placeholder:text-zinc-600 focus:ring-1 focus:ring-unicode/20"
    />
  </div>
  
  <button class="flex items-center gap-2 bg-zinc-900/50 border border-zinc-800 rounded-full px-6 py-3 hover:border-unicode transition-colors text-zinc-400 hover:text-white group">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:text-unicode transition-colors"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    Filtros
