---
// Navbar Component
const pathname = Astro.url.pathname;

// Helper function to check if a link is active
const isActive = (path: string) => {
  if (path === "/") return pathname === "/";
  // Check if current page is the exact path or a subpage (for /areas/...)
  return pathname.startsWith(path);
};
---

<nav
  class="w-full bg-[#050505]/95 backdrop-blur-sm fixed top-0 z-50 border-b border-zinc-900"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- LOGO -->
      <a href="/" class="shrink-0 flex items-center gap-2 group">
        <img
          src="/logo-unicode.webp"
          alt="Unicode"
          class="w-8 h-8 object-contain group-hover:opacity-90 transition-opacity"
        />
        <span
          class="text-unicode font-bold text-xl tracking-wider text-glow transition-colors"
          >UNICODE</span
        >
      </a>

      <!-- LINKS (Desktop) -->
      <div class="hidden md:flex space-x-8">
        <a
          href="/areas"
          class={`transition-colors font-medium text-sm lg:text-base ${isActive("/areas") ? "text-unicode" : "text-gray-300 hover:text-unicode"}`}
          >Áreas</a
        >
        <a
          href="/eventos"
          class={`transition-colors font-medium text-sm lg:text-base ${isActive("/eventos") ? "text-unicode" : "text-gray-300 hover:text-unicode"}`}
          >Eventos</a
        >
        <a
          href="/projects"
          class={`transition-colors font-medium text-sm lg:text-base ${isActive("/projects") ? "text-unicode" : "text-gray-300 hover:text-unicode"}`}
          >Proyectos</a
        >
        <a
          href="/call"
          class={`transition-colors font-medium text-sm lg:text-base ${isActive("/call") ? "text-unicode" : "text-gray-300 hover:text-unicode"}`}
          >Convocatoria</a
        >
      </div>

      <!-- BOTON MENU MOBILE -->
      <div class="md:hidden flex items-center">
        <button
          id="mobile-menu-btn"
          class="group relative w-10 h-10 text-zinc-300 hover:text-white focus:outline-hidden flex flex-col justify-center items-center gap-[6px]"
          aria-label="Abrir menú"
        >
          <span
            class="block w-6 h-[2px] bg-current rounded-full transition-all duration-300 origin-center group-[.is-active]:translate-y-[8px] group-[.is-active]:rotate-45"
          ></span>
          <span
            class="block w-6 h-[2px] bg-current rounded-full transition-all duration-300 origin-center group-[.is-active]:opacity-0 group-[.is-active]:scale-0"
          ></span>
          <span
            class="block w-6 h-[2px] bg-current rounded-full transition-all duration-300 origin-center group-[.is-active]:-translate-y-[8px] group-[.is-active]:-rotate-45"
          ></span>
        </button>
      </div>
    </div>
  </div>

  <!-- MENU MOBILE DESPLEGABLE -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-[#050505]/95 border-t border-zinc-900 px-4 pt-2 pb-4 space-y-2 text-center shadow-lg"
  >
    <a
      href="/areas"
      class={`block px-3 py-3 text-base font-medium transition-colors hover:bg-zinc-800/50 rounded-md ${isActive("/areas") ? "text-unicode" : "text-gray-300 hover:text-white"}`}
      >Áreas</a
    >
    <a
      href="/eventos"
      class={`block px-3 py-3 text-base font-medium transition-colors hover:bg-zinc-800/50 rounded-md ${isActive("/eventos") ? "text-unicode" : "text-gray-300 hover:text-white"}`}
      >Eventos</a
    >
    <a
      href="/projects"
      class={`block px-3 py-3 text-base font-medium transition-colors hover:bg-zinc-800/50 rounded-md ${isActive("/projects") ? "text-unicode" : "text-gray-300 hover:text-white"}`}
      >Proyectos</a
    >
    <a
      href="/call"
      class={`block px-3 py-3 text-base font-medium transition-colors hover:bg-zinc-800/50 rounded-md ${isActive("/call") ? "text-unicode" : "text-gray-300 hover:text-white"}`}
      >Convocatoria</a
    >
  </div>
</nav>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (btn && menu) {
      // Usamos onclick para no duplicar listeners si se ejecuta varias veces
      btn.onclick = () => {
        menu.classList.toggle("hidden");
        btn.classList.toggle("is-active");
      };
    }
  }

  // Inicializar en carga inicial
  setupMobileMenu();
  // Reinicializar si se usa ViewTransitions (Astro)
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
