---
// Navbar Component
---

<nav
  class="w-full bg-[#050505]/95 backdrop-blur-sm fixed top-0 z-50 border-b border-zinc-900"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- LOGO -->
      <a href="/" class="shrink-0 flex items-center gap-2 group">
        <div
          class="w-8 h-8 bg-unicode rounded-lg flex items-center justify-center font-bold text-black group-hover:bg-unicode-light transition-colors"
        >
          U
        </div>
        <span
          class="text-white font-extrabold text-xl tracking-wider text-glow group-hover:text-unicode transition-colors"
          >UNICODE</span
        >
      </a>

      <!-- LINKS (Desktop) -->
      <div class="hidden md:flex space-x-8">
        <a
          href="/areas"
          class="text-gray-300 hover:text-unicode transition-colors font-medium text-sm lg:text-base"
          >Áreas</a
        >
        <a
          href="/eventos"
          class="text-gray-300 hover:text-unicode transition-colors font-medium text-sm lg:text-base"
          >Eventos</a
        >
        <a
          href="/projects"
          class="text-gray-300 hover:text-unicode transition-colors font-medium text-sm lg:text-base"
          >Proyectos</a
        >
        <a
          href="/call"
          class="text-gray-300 hover:text-unicode transition-colors font-medium text-sm lg:text-base"
          >Convocatoria</a
        >
      </div>
    </div>
  </div>
</nav>
