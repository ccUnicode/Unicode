---
// Navbar Component
---

<nav
  class="w-full bg-[#050505]/95 backdrop-blur-sm fixed top-0 z-50 border-b border-zinc-900"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- LOGO -->
      <div class="flex-shrink-0 flex items-center gap-2">
        <div
          class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center font-bold text-black"
        >
          U
        </div>
        <span class="text-white font-extrabold text-xl tracking-wider"
          >UNICODE</span
        >
      </div>

      <!-- LINKS (Desktop) -->
      <div class="hidden md:flex space-x-8">
        <a
          href="/areas"
          class="text-gray-300 hover:text-green-500 transition-colors font-medium text-sm lg:text-base"
          >Áreas</a
        >
        <a
          href="/eventos"
          class="text-gray-300 hover:text-green-500 transition-colors font-medium text-sm lg:text-base"
          >Eventos</a
        >
        <a
          href="/proyectos"
          class="text-gray-300 hover:text-green-500 transition-colors font-medium text-sm lg:text-base"
          >Proyectos</a
        >
        <a
          href="/convocatoria"
          class="text-gray-300 hover:text-green-500 transition-colors font-medium text-sm lg:text-base"
          >Convocatoria</a
        >
      </div>
    </div>
