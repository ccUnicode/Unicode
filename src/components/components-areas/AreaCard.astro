---
interface Director {
    name: string;
    image: string;
    linkedin?: string;
}

interface Props {
    title: string;
    description: string;
    directors: Director[];
    imageSrc?: string;
    reverse?: boolean;
}

const {
    title,
    description,
    directors,
    imageSrc = "https://placehold.co/600x600/18181b/75D32D?text=Imágen",
    reverse = false,
} = Astro.props;
---

<div
    class={`flex flex-row gap-4 sm:gap-6 md:gap-8 bg-[#151515] rounded-2xl md:rounded-[2rem] p-4 sm:p-5 md:p-6 items-center border border-zinc-800/50 hover:border-unicode/30 transition-all duration-300 group ${reverse ? "md:flex-row-reverse" : ""}`}
>
    <!-- Contenedor de Imagen -->
    <div
        class="w-[35%] sm:w-[40%] md:w-[25%] xl:w-[22%] max-w-[140px] md:max-w-[280px] flex-shrink-0 self-stretch rounded-2xl md:rounded-3xl overflow-hidden border border-transparent md:border-2 group-hover:border-unicode/40 transition-all duration-500 group-hover:shadow-unicode"
    >
        <img
            src={imageSrc}
            alt={`Imagen del área de ${title}`}
            class="w-full h-full object-cover"
            loading="lazy"
        />
    </div>

    <!-- Contenedor de Información -->
    <div
        class={`w-[65%] sm:w-[60%] md:w-[75%] xl:w-[78%] flex flex-col justify-center py-1 md:py-2 ${reverse ? "md:items-end text-left md:text-right" : "items-start text-left"}`}
    >
        <h3
            class="text-[20px] sm:text-2xl md:text-3xl lg:text-4xl font-semibold text-unicode text-glow mb-1 md:mb-4"
        >
            {title}
        </h3>

        <p
            class="text-zinc-300 text-[13px] sm:text-sm md:text-base leading-snug md:leading-relaxed mb-3 md:mb-5 font-normal line-clamp-4 md:line-clamp-none"
        >
            {description}
        </p>

        <!-- Directores con fotos y LinkedIn -->
        <div class={`flex gap-4 mb-3 md:mb-6 ${reverse ? "md:justify-end" : ""}`}>
            {directors.map((director) => (
                <div class="flex items-center gap-2">
                    <!-- Foto del director -->
                    <div class="w-8 h-8 md:w-10 md:h-10 rounded-full overflow-hidden border border-zinc-700 group-hover:border-unicode/50 transition-colors duration-300 flex-shrink-0">
                        <img
                            src={director.image}
                            alt={director.name}
                            class="w-full h-full object-cover"
                            loading="lazy"
                        />
                    </div>
                    <!-- Nombre + icono LinkedIn -->
                    <div class="flex flex-col leading-tight">
                        <span class="text-zinc-200 text-[11px] sm:text-xs md:text-sm font-semibold">{director.name}</span>
                        {director.linkedin && (
                            <a
                                href={director.linkedin}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex items-center gap-1 text-zinc-400 hover:text-[#0A66C2] transition-colors duration-200 mt-0.5"
                                aria-label={`LinkedIn de ${director.name}`}
                            >
                                <!-- Icono LinkedIn -->
                                <svg class="w-3 h-3 md:w-3.5 md:h-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                                </svg>
                                <span class="text-[10px] md:text-xs">LinkedIn</span>
                            </a>
                        )}
                    </div>
                </div>
            ))}
        </div>

        <a
            href={`/areas/${title.toLowerCase().replace(/\s+/g, "-")}`}
            class="bg-unicode text-black font-bold px-4 py-2 md:px-8 md:py-3 rounded-full hover:bg-unicode-light transition-all w-fit text-[12px] sm:text-sm md:text-base shadow-unicode hover:shadow-unicode-lg"
        >
            Conoce más
        </a>
    </div>
</div>
