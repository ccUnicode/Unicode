---
interface Props {
    title: string;
    description: string;
    directorLabel: string;
    directorNames: string;
    imageSrc?: string;
    reverse?: boolean;
}

const {
    title,
    description,
    directorLabel,
    directorNames,
    imageSrc = "https://placehold.co/600x600/18181b/75D32D?text=Imágen",
    reverse = false,
} = Astro.props;
---

<div
    class={`flex flex-col md:flex-row gap-6 md:gap-8 bg-[#151515] rounded-[2rem] p-5 md:p-6 items-center border border-zinc-800/50 hover:border-unicode/30 transition-all duration-300 group ${reverse ? "md:flex-row-reverse" : ""}`}
>
    <!-- Contenedor de Imagen -->
    <div
        class="w-full md:w-[25%] xl:w-[22%] max-w-[280px] flex-shrink-0 rounded-3xl overflow-hidden border-2 border-transparent group-hover:border-unicode/40 transition-all duration-500 group-hover:shadow-unicode"
    >
        <img
            src={imageSrc}
            alt={`Imagen del área de ${title}`}
            class="w-full aspect-square object-cover"
        />
    </div>

    <!-- Contenedor de Información -->
    <div
        class={`w-full md:w-[75%] xl:w-[78%] flex flex-col justify-center py-2 ${reverse ? "md:items-end md:text-right text-left" : "md:items-start text-left"}`}
    >
        <h3 class="text-4xl md:text-5xl font-bold text-unicode text-glow mb-4">
            {title}
        </h3>

        <p class="text-zinc-300 text-[16px] leading-relaxed mb-5 font-normal">
            {description}
        </p>

        <div class="mb-6 text-[16px]">
            <span class="text-unicode font-bold">{directorLabel}</span>
            <span class="text-zinc-300"> {directorNames}</span>
        </div>

        <a
            href={`/areas/${title.toLowerCase().replace(/\s+/g, "-")}`}
            class="bg-unicode text-white font-bold px-8 py-3 rounded-full hover:bg-unicode-light transition-all w-fit text-[16px] shadow-unicode hover:shadow-unicode-lg"
        >
            Conoce más
        </a>
    </div>
</div>
