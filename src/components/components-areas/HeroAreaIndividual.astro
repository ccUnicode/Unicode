---
import AreaRequirement from "./AreaRequirement.astro";
import AreaValor from "./AreaValor.astro";
import AreaWinCard from "./AreaWinCard.astro";
import AreaProjectCard from "./AreaProjectCard.astro";
import AreaDirectorProfile from "./AreaDirectorProfile.astro";
import AreaProjectSlider from "./AreaProjectSlider.astro";

interface Project {
    title: string;
    description: string;
    imageSrc: string;
    status?: string;
}

interface Director {
    name: string;
    linkedin: string;
    imageSrc: string;
}

interface Props {
    title: string;
    description: string;
    whatWeLookFor?: string[];
    weValue?: string[];
    whatYouWin?: string[];
    projects?: Project[];
    directors?: Director[];
}

const { 
    title, 
    description,
    whatWeLookFor = [],
    weValue = [],
    whatYouWin = [],
    projects = [],
    directors = []
} = Astro.props;
---

<main class="w-full min-h-screen relative pt-32 pb-24 bg-[#050505] overflow-hidden">
    <!-- Imagen de fondo decorativa (Mascota) -->
    <div class="absolute top-30 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[750px] pointer-events-none z-0 opacity-35">
        <img 
            src="/areaspage.png" 
            alt="" 
            class="w-full h-full object-contain object-top"
        />
    </div>


<!-- Arriba está la img, no confundir -->


    <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col items-start w-full">
        <!-- Título y Descripción base de todas las páginas de áreas -->
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 mt-20 tracking-tight animate-lifting">
            Área de <span class="text-unicode text-glow">{title}</span>
        </h1>

        <p class="text-zinc-300 text-[18px] md:text-[20px] max-w-3xl leading-relaxed mb-10 animate-lifting" style="animation-delay: 100ms;">
            {description}
        </p>

        <!-- Botones de navegación interna (proyectos y directores) -->
        <div class="flex gap-4 mb-20 animate-lifting" style="animation-delay: 150ms;">
            {projects.length > 0 && (
                <a 
                    href="#nuestros-proyectos" 
                    class="bg-unicode text-black font-bold px-8 py-3 rounded-full hover:bg-unicode-light transition-all shadow-unicode hover:shadow-unicode-lg text-sm md:text-base"
                >
                    Proyectos
                </a>
            )}
            {directors.length > 0 && (
                <a 
                    href="#nuestros-directores" 
                    class="bg-zinc-900 text-white font-bold px-8 py-3 rounded-full border border-zinc-800 hover:border-zinc-700 transition-all text-sm md:text-base"
                >
                    Directores
                </a>
            )}
        </div>

        <!-- Slot base por si acaso alguna página necesita meter HTML a la fuerza -->
        <div class="w-full flex-col">
            <slot />
        </div>

        <!-- SECCIÓN 1: Buscamos & Valoramos -->
        {(whatWeLookFor.length > 0 || weValue.length > 0) && (
            <div class="w-full flex flex-col lg:flex-row lg:justify-between gap-12 mb-24 mt-16">
                <!-- Columna: ¿Qué buscamos? -->
                {whatWeLookFor.length > 0 && (
                    <div class="lg:w-[60%] flex flex-col gap-5 animate-lifting" style="animation-delay: 300ms;">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">¿Qué buscamos en {title}?</h2>
                        {whatWeLookFor.map(text => <AreaRequirement text={text} />)}
                    </div>
                )}
                
                <!-- Columna: Valoramos... -->
                {weValue.length > 0 && (
                    <div class="lg:w-[32%] flex flex-col gap-6 animate-lifting" style="animation-delay: 300ms;">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Valoramos...</h2>
                        {weValue.map(text => <AreaValor text={text} />)}
                    </div>
                )}
            </div>
        )}

        <!-- SECCIÓN 2: ¿Qué ganas? -->
        {whatYouWin.length > 0 && (
            <div class="w-full border border-[#203610] bg-[#0A0D08] rounded-[2rem] p-8 md:p-12 mb-32 relative overflow-hidden mt-8 animate-lifting" style="animation-delay: 400ms;">
                <!-- Efecto Glow de fondo -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] h-[120px] bg-[#3B7F15]/15 blur-[60px] pointer-events-none rounded-full"></div>
                
                <h2 class="text-3xl md:text-4xl font-bold text-unicode text-glow mb-12 text-center relative z-10">¿Qué ganas?</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 relative z-10">
                    {whatYouWin.map(text => <AreaWinCard text={text} />)}
                </div>
            </div>
        )}

        <!-- SECCIÓN 3: Proyectos -->
        {projects.length > 0 && (
            <div id="nuestros-proyectos" class="w-full mb-32 flex flex-col items-center scroll-mt-24 animate-lifting" style="animation-delay: 500ms;">
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-8 text-center">Nuestros <span class="text-unicode text-glow">Proyectos</span></h2>
                
                <AreaProjectSlider projects={projects} />
            </div>
        )}

        <!-- SECCIÓN 4: Directores -->
        {directors.length > 0 && (
            <div id="nuestros-directores" class="w-full mb-16 flex flex-col items-center scroll-mt-24 animate-lifting" style="animation-delay: 600ms;">
                <h2 class="text-3xl md:text-4xl font-bold text-unicode text-glow mb-16 text-center">Directores</h2>
                
                <div class="flex flex-wrap justify-center gap-16 md:gap-32">
                    {directors.map(d => <AreaDirectorProfile name={d.name} linkedin={d.linkedin} imageSrc={d.imageSrc} />)}
                </div>
            </div>
        )}
    </div>
</main>


<style>
    .animate-lifting {
        opacity: 0;
        transform: translateY(20px);
        animation: reveal 0.8s cubic-bezier(0.2, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
