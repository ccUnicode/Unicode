                        linkedin: "https://www.linkedin.com/in/lenincastro/",
                    },
                    {
                        name: "Gabriel Chupa",
                        image: "/areas/AreasImages/Gabriel_Chupa.webp",
                        linkedin:
                            "https://www.linkedin.com/in/gabriel-chupa-ballesteros/",
