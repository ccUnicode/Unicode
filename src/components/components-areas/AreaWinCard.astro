---
interface Props {
    text: string;
}

const { text } = Astro.props;
---

<div class="flex items-start gap-4">
    <!-- Contenedor reservado para la imagen iconográfica (Logotipo verde de UNICODE) -->
    <div
        class="w-8 h-8 flex-shrink-0 rounded-full bg-zinc-800/50 flex items-center justify-center overflow-hidden border border-[#75D32D]/30 p-0"
    >
        <img
            src="/logo-unicode.png"
            alt="Unicode Logo"
            class="w-full h-full object-contain"
        />
    </div>

    <!-- Texto -->
    <p class="text-zinc-300 text-sm md:text-base leading-relaxed flex-1">
        {text}
    </p>
</div>
