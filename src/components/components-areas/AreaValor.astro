---
interface Props {
    text: string;
}

const { text } = Astro.props;
---

<div class="flex items-start gap-3">
    <!-- Ícono Check SVG -->
    <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="flex-shrink-0 mt-0.5 mt-1"
    >
        <path
            d="M5 13L9 17L19 7"
            stroke="#A1A1AA"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
    </svg>

    <!-- Texto -->
    <p class="text-zinc-300 text-[15px] leading-relaxed">
        {text}
    </p>
</div>
