---
// Hero Component
---

<section
  class="min-h-[calc(100vh-80px)] pt-20 pb-12 md:pt-24 flex items-center relative overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left Column: Content -->
      <div
        class="flex flex-col text-left justify-center order-2 lg:order-1 mt-8 lg:mt-0"
      >
        <!-- Logo Text inline with SVG -->
        <div class="flex flex-wrap items-center gap-3 md:gap-4 mb-4 md:mb-6">
          <img
            src="/logo-unicode.png"
            alt="Unicode Logo"
            class="w-10 h-10 md:w-14 md:h-14 lg:w-16 lg:h-16 object-contain drop-shadow-[0_0_15px_rgba(117,211,45,0.4)] shrink-0"
          />
          <span
            class="text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] font-semibold text-unicode tracking-tight text-glow uppercase leading-none"
            style="font-family: 'Poppins', sans-serif;"
          >
            UNICODE
          </span>
        </div>

        <h1
          class="text-3xl sm:text-4xl md:text-[2.5rem] lg:text-[2.75rem] font-semibold text-white mb-5 md:mb-6 tracking-tight leading-[1.2]"
        >
          Conectando propósitos, <br />
          creando oportunidades.
        </h1>

        <p
          class="text-zinc-300 text-sm sm:text-base md:text-lg lg:text-xl max-w-2xl mb-8 leading-relaxed font-normal"
        >
          Velando por el bienestar estudiantil, la información, educación y
          conocimiento de nuestra comunidad universitaria.
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-col sm:flex-row items-center sm:items-start justify-start gap-4 sm:gap-5"
        >
          <a
            href="/areas"
            class="w-full sm:w-auto px-6 py-3 bg-unicode hover:bg-unicode-light text-[#050505] font-semibold rounded-2xl transition-all duration-300 text-base shadow-unicode hover:shadow-unicode-lg text-center truncate"
          >
            Conócenos
          </a>
          <a
            href="/convocatoria"
            class="w-full sm:w-auto px-6 py-3 bg-zinc-900 hover:bg-zinc-800 text-white font-semibold rounded-2xl transition-all duration-300 text-base text-center truncate"
          >
            Novedades
          </a>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div
        class="relative w-full h-[320px] sm:h-[420px] lg:h-[550px] flex justify-center items-center order-1 lg:order-2"
      >
        <img
          src="/Mascota-Unicode-Landing-Hero.png"
          alt="Mascota Unicode"
          class="w-full h-full object-contain filter drop-shadow-[0_0_40px_rgba(117,211,45,0.15)] animate-float"
          style="animation: float 6s ease-in-out infinite;"
        />

        <!-- Glow effect behind mascot -->
        <div
          class="absolute inset-0 bg-unicode/5 blur-[120px] rounded-full z-[-1] transform scale-75 hidden lg:block"
        >
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes float {
      0% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
      100% {
        transform: translateY(0px);
      }
    }
  </style>
</section>
