---

---

<section
  class="min-h-screen pt-24 pb-12 flex items-center justify-center relative overflow-hidden"
>
  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-unicode/10 border border-unicode/20 text-unicode font-bold mb-8 text-sm tracking-wide"
    >
      <span
        class="w-2 h-2 rounded-full bg-unicode shadow-[0_0_8px_rgba(117,211,45,0.8)] animate-pulse"
      ></span>
      CENTRO CULTURAL FIIS UNI
    </div>

    <h1
      class="text-4xl md:text-6xl font-bold text-white mb-8 tracking-tight leading-[1.1]"
    >
      Conectando propósitos, <br />
      <span class="text-unicode text-glow animate-glow"
        >creando oportunidades.</span
      >
    </h1>

    <p
      class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed font-medium"
    >
      Velando por el bienestar estudiantil, la información, educación y
      conocimiento de nuestra comunidad universitaria.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a
        href="/areas"
        class="w-full sm:w-auto px-10 py-4 bg-unicode hover:bg-unicode-light text-black font-bold rounded-full transition-all duration-300 text-lg shadow-unicode hover:shadow-unicode-lg transform hover:-translate-y-1 text-center"
      >
        Conócenos
      </a>
      <a
        href="/convocatoria"
        class="w-full sm:w-auto px-10 py-4 bg-zinc-950 border border-unicode/30 hover:border-unicode text-white font-bold rounded-full transition-all duration-300 text-lg hover:text-unicode backdrop-blur-sm text-center"
      >
        Novedades
      </a>
    </div>
  </div>
</section>
