---
// Hero Component
---

<section
  class="min-h-[calc(100vh-80px)] pt-20 pb-12 md:pt-24 flex items-center relative overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      <!-- Left Column: Content -->
      <div
        class="flex flex-col text-left justify-center order-2 lg:order-1 mt-8 lg:mt-0"
      >
        <!-- Logo Text inline with SVG -->
        <div class="flex flex-wrap items-center gap-3 md:gap-4 mb-4 md:mb-6">
          <svg
            viewBox="0 0 100 100"
            class="w-12 h-12 md:w-[72px] md:h-[72px] fill-unicode drop-shadow-[0_0_15px_rgba(117,211,45,0.4)] shrink-0"
          >
            <!-- Left parenthetical arc -->
            <path d="M 33 5 C 10 30 10 70 33 95 L 43 95 C 22 70 22 30 43 5 Z"
            ></path>
            <!-- Middle 1 -->
            <path d="M 50 25 L 60 15 L 63 15 L 63 95 L 53 95 L 53 25 Z"></path>
            <!-- Right parenthetical arc -->
            <path d="M 77 5 C 100 30 100 70 77 95 L 67 95 C 88 70 88 30 67 5 Z"
            ></path>
          </svg>
          <span
            class="text-[2.75rem] sm:text-6xl md:text-7xl lg:text-[5rem] font-bold text-unicode tracking-tight text-glow uppercase leading-none"
            style="font-family: 'Poppins', sans-serif;"
          >
            UNICODE
          </span>
        </div>

        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] font-bold text-white mb-6 md:mb-8 tracking-tight leading-[1.1]"
        >
          Conectando propósitos, <br class="hidden sm:block" />
          creando oportunidades.
        </h1>

        <p
          class="text-zinc-200 text-base sm:text-lg md:text-xl lg:text-[22px] max-w-2xl mb-10 leading-relaxed font-medium"
        >
          Velando por el bienestar estudiantil, la información, educación y
          conocimiento de nuestra comunidad universitaria.
        </p>

        <!-- CTAs -->
        <div
          class="flex flex-col sm:flex-row items-center sm:items-start justify-start gap-4 sm:gap-6"
        >
          <a
            href="/areas"
            class="w-full sm:w-auto px-8 py-3.5 bg-unicode hover:bg-unicode-light text-[#050505] font-bold rounded-2xl transition-all duration-300 text-lg shadow-unicode hover:shadow-unicode-lg text-center truncate"
          >
            Conócenos
          </a>
          <a
            href="/convocatoria"
            class="w-full sm:w-auto px-8 py-3.5 bg-zinc-900 hover:bg-zinc-800 text-white font-bold rounded-2xl transition-all duration-300 text-lg text-center truncate"
          >
            Novedades
          </a>
        </div>
      </div>

      <!-- Right Column: Image -->
      <div
        class="relative w-full h-[400px] sm:h-[500px] lg:h-[650px] flex justify-center items-center order-1 lg:order-2"
      >
        <img
          src="/Mascota-Unicode-Landing-Hero.png"
          alt="Mascota Unicode"
          class="w-full h-full object-contain filter drop-shadow-[0_0_40px_rgba(117,211,45,0.15)] animate-float"
          style="animation: float 6s ease-in-out infinite;"
        />

        <!-- Glow effect behind mascot -->
        <div
          class="absolute inset-0 bg-unicode/5 blur-[120px] rounded-full z-[-1] transform scale-75 hidden lg:block"
        >
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes float {
      0% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
      100% {
        transform: translateY(0px);
      }
    }
  </style>
</section>
