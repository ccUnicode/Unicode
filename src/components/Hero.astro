---

---

<section
  class="min-h-screen pt-24 pb-12 flex items-center justify-center relative overflow-hidden"
>
  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <div
      class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 text-green-400 font-semibold mb-6"
    >
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
      Centro Cultural FIIS UNI
    </div>

    <h1
      class="text-5xl md:text-7xl font-extrabold text-white mb-8 tracking-tight"
    >
      Conectando propósitos, <br />
      <span class="text-green-500">creando oportunidades.</span>
    </h1>

    <p class="text-zinc-400 text-lg md:text-xl max-w-2xl mx-auto mb-10">
      Velando por el bienestar estudiantil, la información, educación y
      conocimiento de nuestra comunidad universitaria.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/areas"
        class="w-full sm:w-auto px-8 py-3 bg-green-500 hover:bg-green-400 text-black font-bold rounded-full transition-colors text-lg"
      >
        Conócenos
      </a>
      <a
        href="/convocatoria"
        class="w-full sm:w-auto px-8 py-3 bg-zinc-900 border border-zinc-700 hover:border-green-500 hover:text-green-500 text-white font-bold rounded-full transition-all text-lg"
      >
        Novedades
      </a>
    </div>
  </div>
</section>
