---

---

<dialog
  id="project-modal"
  class="fixed inset-0 m-auto bg-zinc-950 border border-unicode rounded-3xl p-0 w-[95%] max-w-5xl h-fit max-h-[90vh] text-white backdrop:bg-black/80 backdrop:backdrop-blur-sm open:animate-in open:fade-in open:zoom-in-95 outline-none overflow-hidden"
>
  <div
    class="p-4 md:p-12 lg:p-16 relative max-h-[85vh] overflow-y-auto custom-scrollbar"
  >
    <!-- Close btn -->
    <button
      id="close-project-modal"
      class="absolute top-6 right-6 md:top-8 md:right-8 lg:top-10 lg:right-10 text-zinc-400 hover:text-white transition-colors p-1 cursor-pointer"
      aria-label="Cerrar modal"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="text-center mb-8 md:mb-12 px-4 md:px-12">
      <h2
        id="modal-project-title"
        class="text-xl md:text-4xl font-bold text-white tracking-tight uppercase"
      >
        SGA Unicode
      </h2>
    </div>

    <div id="modal-grid-container" class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 items-stretch">
      <!-- Descripcion -->
      <div 
        id="modal-desc-container" 
        class="border border-zinc-800 bg-[#0d0d0d] rounded-3xl p-10 md:p-12 col-span-1 md:col-span-2 transition-all duration-300"
      >
        <h3 class="text-unicode text-xl mb-4 font-bold">Descripción</h3>
        <p
          id="modal-project-desc"
          class="text-zinc-300 text-sm md:text-base leading-relaxed"
        >
          SGA Unicode es una plataforma...
        </p>
      </div>

      <!-- Screenshots Container -->
      <div id="modal-screenshots-wrapper" class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div
          id="modal-screenshot-1-container"
          class="border border-zinc-800 bg-[#0d0d0d] rounded-3xl overflow-hidden min-h-[220px] md:min-h-[300px] transition-all duration-300"
        >
          <img
            id="modal-screenshot-1"
            src=""
            alt="Screenshot 1"
            class="w-full h-full object-cover opacity-80"
          />
        </div>
        <div
          id="modal-screenshot-2-container"
          class="border border-zinc-800 bg-[#0d0d0d] rounded-3xl overflow-hidden min-h-[220px] md:min-h-[300px] transition-all duration-300"
        >
          <img
            id="modal-screenshot-2"
            src=""
            alt="Screenshot 2"
            class="w-full h-full object-cover opacity-80"
          />
        </div>
      </div>
    </div>

    <!-- Our team (Nuestro equipo) -->
    <div
      class="bg-[#111111] border border-zinc-800 rounded-3xl p-6 md:p-16 mb-8"
    >
      <h3 class="text-center text-3xl font-bold text-white mb-10">
        Nuestro <span class="text-unicode">equipo</span>
      </h3>

      <div
        id="modal-project-team"
        class="flex flex-wrap justify-center gap-y-10 gap-x-3 md:gap-x-12 text-center"
      >
        <!-- JS Team injected here -->
      </div>
    </div>

    <!-- Call to action button -->
    <div class="flex justify-center mt-8">
      <a
        id="modal-project-link"
        href="#"
        target="_blank"
        class="px-8 py-3 bg-unicode text-black font-bold rounded-full hover:bg-unicode/90 transition-all hover:scale-105 active:scale-95 text-sm md:text-base shadow-[0_0_15px_rgba(117,211,45,0.3)] text-center"
      >
        Click aquí para conocer SGA Unicode
      </a>
    </div>
  </div>
</dialog>

<style>
  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
  }
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #0a0a0a;
    border-radius: 8px;
    margin-block: 35px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #75d32d;
    border-radius: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #5bba20;
  }
  .custom-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: #75d32d #0a0a0a;
  }
</style>

<script>
  function initModals() {
    const triggers = document.querySelectorAll(".js-open-project-modal");
    const modal = document.getElementById("project-modal") as HTMLDialogElement;
    const closeBtn = document.getElementById("close-project-modal");

    // Modal Elements
    const titleEl = document.getElementById("modal-project-title");
    const descEl = document.getElementById("modal-project-desc");
    const descContainer = document.getElementById("modal-desc-container");
    const screenshotsWrapper = document.getElementById("modal-screenshots-wrapper");
    const img1El = document.getElementById(
      "modal-screenshot-1",
    ) as HTMLImageElement;
    const img2El = document.getElementById(
      "modal-screenshot-2",
    ) as HTMLImageElement;
    const img1Container = document.getElementById("modal-screenshot-1-container");
    const img2Container = document.getElementById("modal-screenshot-2-container");
    
    const teamContainer = document.getElementById("modal-project-team");
    const linkEl = document.getElementById(
      "modal-project-link",
    ) as HTMLAnchorElement;

    if (!modal) return;

    triggers.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        const projectData = btn.getAttribute("data-project");
        if (projectData) {
          const project = JSON.parse(projectData);

          if (titleEl) titleEl.textContent = project.title;
          if (descEl)
            descEl.textContent = project.longDescription || project.description;

          const screenshots = project.screenshots || [];
          const numScreens = screenshots.length;

          // Reset classes before applying new layout
          if (descContainer) {
            descContainer.classList.remove("md:col-span-1", "md:col-span-2");
          }
          if (screenshotsWrapper) {
            screenshotsWrapper.classList.remove("md:col-span-1", "md:col-span-2", "grid-cols-1", "md:grid-cols-2", "hidden");
            screenshotsWrapper.classList.add("grid");
          }

          if (numScreens === 1) {
            // Layout: Description (left), Photo (right)
            if (descContainer) descContainer.classList.add("md:col-span-1");
            if (screenshotsWrapper) {
              screenshotsWrapper.classList.add("md:col-span-1", "grid-cols-1");
            }
            if (img1El) {
              img1El.src = screenshots[0];
              img1Container?.classList.remove("hidden");
            }
            img2Container?.classList.add("hidden");
          } else if (numScreens >= 2) {
            // Layout: Description (full width), Photos (2 cols below)
            if (descContainer) descContainer.classList.add("md:col-span-2");
            if (screenshotsWrapper) {
              screenshotsWrapper.classList.add("md:col-span-2", "grid-cols-1", "md:grid-cols-2");
            }
            if (img1El) {
              img1El.src = screenshots[0];
              img1Container?.classList.remove("hidden");
            }
            if (img2El) {
              img2El.src = screenshots[1];
              img2Container?.classList.remove("hidden");
            }
          } else {
            // No screenshots
            if (descContainer) descContainer.classList.add("md:col-span-2");
            screenshotsWrapper?.classList.add("hidden");
          }

          if (linkEl) {
            linkEl.href = project.link || "#";
            linkEl.textContent = `Click aquí para conocer ${project.title}`;
          }

          // Populate Team
          if (teamContainer) {
            teamContainer.innerHTML = "";
            const team = project.team || [];
            team.forEach((member: any) => {
              teamContainer.innerHTML += `
                <div class="flex flex-col items-center group w-[calc(50%-8px)] md:w-[calc(33.33%-32px)] min-w-[130px] max-w-[160px]">
                 <div class="w-20 h-20 md:w-24 md:h-24 mb-3 md:mb-4 rounded-full overflow-hidden border-2 border-zinc-800 bg-[#1a1a1a] flex items-center justify-center relative shadow-[0_0_15px_rgba(0,0,0,0.5)] group-hover:border-unicode transition-colors duration-300">
                    <div class="absolute inset-0 bg-gradient-to-t from-unicode/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    ${member.image
                      ? `<img src="${member.image}" alt="${member.name}" class="w-full h-full object-cover absolute" loading="lazy" />`
                      : `<svg class="w-8 h-8 md:w-10 md:h-10 text-zinc-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>`
                    }
                 </div>
                 <h4 class="text-white font-bold text-xs md:text-base leading-tight">${member.name}</h4>
                 <div class="flex items-center gap-1 mt-1 text-zinc-400">
                    <svg class="w-3.5 h-3.5 text-[#0077B5] shrink-0" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                    </svg>
                     <a href="https://linkedin.com/in/${member.linkedin}" target="_blank" class="text-[10px] md:text-xs hover:text-unicode transition-colors cursor-pointer font-medium">LinkedIn</a>
                  </div>
                </div>
              `;
            });
          }

          modal.showModal();
          document.body.style.overflow = "hidden";
        }
      });
    });

    closeBtn?.addEventListener("click", () => {
      modal.close();
      document.body.style.overflow = "";
    });

    // Close when clicking outside of modal
    modal.addEventListener("click", (event) => {
      const rect = modal.getBoundingClientRect();
      const isInDialog =
        rect.top <= event.clientY &&
        event.clientY <= rect.top + rect.height &&
        rect.left <= event.clientX &&
        event.clientX <= rect.left + rect.width;
      if (!isInDialog) {
        modal.close();
        document.body.style.overflow = "";
      }
    });
  }

  // Load modal js
  initModals();
  document.addEventListener("astro:page-load", initModals);
</script>
