---
/**
 * Alianzas.astro
 * Sección "NUESTRAS ALIANZAS" con grid de logos de organizaciones aliadas.
 */

interface Alianza {
  name: string;
  logo: string; // SVG inline o texto
}

const alianzas: Alianza[] = [
  { name: "Hult Prize", logo: "hult-prize" },
  { name: "IEEE", logo: "ieee" },
  { name: "Open Source", logo: "open-source" },
  { name: "Tech Community", logo: "tech-community" },
  { name: "Data Science", logo: "data-science" },
  { name: "OSCE", logo: "osce" },
  { name: "Futura", logo: "futura" },
  { name: "ACM", logo: "acm" },
  { name: "Microsoft", logo: "microsoft" },
  { name: "Developers", logo: "developers" },
  { name: "Android", logo: "android" },
  { name: "Open AI", logo: "openai" },
];
---

<section id="alianzas" class="w-full py-16 md:py-24 relative">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Título -->
    <div class="text-center mb-6">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight"
      >
        NUESTRAS <span class="text-unicode text-glow">ALIANZAS</span>
      </h2>
    </div>

    <!-- Subtítulo -->
    <p
      class="text-zinc-400 text-sm md:text-base text-center max-w-xl mx-auto mb-14 leading-relaxed"
    >
      Trabajamos de la mano con organizaciones alineadas a nuestros objetivos,
      con el fin de potenciar la educación y fomentar el desarrollo de software
      en la comunidad.
    </p>

    <!-- Grid de logos -->
    <div class="grid grid-cols-4 gap-4 md:gap-6 max-w-2xl mx-auto">
      {
        alianzas.map((alianza) => (
          <div class="group flex items-center justify-center p-4 md:p-6 rounded-xl transition-all duration-300 hover:bg-zinc-900/50">
            {/* Placeholder con nombre del aliado */}
            <div class="flex flex-col items-center gap-2 opacity-60 group-hover:opacity-100 transition-opacity duration-300">
              {alianza.logo === "hult-prize" && (
                <div class="flex items-center gap-1">
                  <span class="text-white font-extrabold text-lg md:text-xl">
                    H
                  </span>
                  <div class="text-left leading-none">
                    <span class="text-white text-[8px] md:text-[10px] font-bold block">
                      Hult
                    </span>
                    <span class="text-white text-[8px] md:text-[10px] font-bold block">
                      Prize
                    </span>
                  </div>
                </div>
              )}
              {alianza.logo === "ieee" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <circle
                    cx="12"
                    cy="12"
                    r="10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                  />
                  <path
                    d="M8 8l8 8M16 8l-8 8"
                    stroke="currentColor"
                    stroke-width="1.5"
                  />
                </svg>
              )}
              {alianza.logo === "open-source" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.047 8.287 8.287 0 009 9.601a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
                  <path d="M12 18a3.75 3.75 0 00.495-7.468 5.99 5.99 0 00-1.925 3.547 5.975 5.975 0 01-2.133-1.001A3.75 3.75 0 0012 18z" />
                </svg>
              )}
              {alianza.logo === "tech-community" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
              )}
              {alianza.logo === "data-science" && (
                <div class="text-white">
                  <div class="flex items-center gap-1">
                    <svg
                      class="w-5 h-5 md:w-6 md:h-6"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"
                      />
                    </svg>
                    <span class="text-[10px] md:text-xs font-bold leading-none">
                      Data
                      <br />
                      Science
                    </span>
                  </div>
                </div>
              )}
              {alianza.logo === "osce" && (
                <span class="text-white font-mono font-bold text-sm md:text-lg tracking-wider">
                  &lt;OSC&gt;
                </span>
              )}
              {alianza.logo === "futura" && (
                <div class="text-white">
                  <span class="font-bold text-sm md:text-base tracking-wider italic">
                    FUTURA
                  </span>
                </div>
              )}
              {alianza.logo === "acm" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
                  />
                </svg>
              )}
              {alianza.logo === "microsoft" && (
                <div class="flex items-center gap-1.5">
                  <div class="grid grid-cols-2 gap-0.5 w-4 h-4">
                    <div class="bg-white rounded-[1px]" />
                    <div class="bg-white rounded-[1px]" />
                    <div class="bg-white rounded-[1px]" />
                    <div class="bg-white rounded-[1px]" />
                  </div>
                  <span class="text-white font-semibold text-xs md:text-sm">
                    Microsoft
                  </span>
                </div>
              )}
              {alianza.logo === "developers" && (
                <span class="text-white font-extrabold text-xl md:text-2xl tracking-tight">
                  &lt;/&gt;
                </span>
              )}
              {alianza.logo === "android" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M17.523 15.342a.998.998 0 01-.001-1.998.998.998 0 01.001 1.998zm-11.046 0a.998.998 0 01-.001-1.998.998.998 0 01.001 1.998zm11.406-6.117l2.001-3.462a.416.416 0 00-.152-.567.416.416 0 00-.568.152l-2.027 3.51a12.198 12.198 0 00-5.137-1.137c-1.821 0-3.536.419-5.137 1.137l-2.027-3.51a.416.416 0 00-.568-.152.416.416 0 00-.152.567l2.001 3.462C2.725 11.475.5 15.14.5 19.317h23c0-4.177-2.225-7.842-5.617-10.092z" />
                </svg>
              )}
              {alianza.logo === "openai" && (
                <svg
                  class="w-8 h-8 md:w-10 md:h-10 text-white"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M22.282 9.821a5.985 5.985 0 00-.516-4.91 6.046 6.046 0 00-6.51-2.9A6.065 6.065 0 0012 0C9.4 0 7.078 1.562 6.097 3.99a6.045 6.045 0 00-4.044 2.928 6.053 6.053 0 00.744 7.103A5.985 5.985 0 003.313 18.93a6.046 6.046 0 006.51 2.9A6.065 6.065 0 0012 24c2.6 0 4.922-1.562 5.903-3.99a6.045 6.045 0 004.044-2.928 6.025 6.025 0 00-.744-7.103l.08.058-.001-.216zM12 22.393a4.474 4.474 0 01-2.874-1.043l.142-.08 4.774-2.76a.773.773 0 00.394-.678v-6.735l2.017 1.166a.071.071 0 01.039.052v5.583a4.504 4.504 0 01-4.492 4.495zm-9.668-4.12a4.475 4.475 0 01-.535-3.015l.142.085 4.774 2.76a.782.782 0 00.787 0l5.83-3.368v2.332a.072.072 0 01-.03.062l-4.828 2.787a4.504 4.504 0 01-6.14-1.641zM1.192 7.938A4.477 4.477 0 013.53 5.95v5.692a.773.773 0 00.393.678l5.83 3.368-2.018 1.166a.071.071 0 01-.068.005l-4.829-2.788A4.504 4.504 0 011.192 7.938zm17.165 3.997l-5.831-3.369 2.018-1.166a.071.071 0 01.068-.005l4.829 2.788a4.495 4.495 0 01-.687 8.116v-5.686a.77.77 0 00-.397-.678zm2.005-3.026l-.142-.085-4.774-2.76a.782.782 0 00-.787 0l-5.83 3.369V7.101a.072.072 0 01.03-.062l4.828-2.787a4.494 4.494 0 016.675 4.657zm-12.63 4.15L5.715 11.89a.071.071 0 01-.039-.052v-5.583a4.494 4.494 0 017.375-3.453l-.142.08-4.774 2.76a.773.773 0 00-.394.678l-.003 6.75zm1.096-2.365l2.597-1.5 2.597 1.5v3l-2.597 1.5-2.597-1.5z" />
                </svg>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
