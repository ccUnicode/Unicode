---
/**
 * Novedades.astro
 * Sección de noticias debajo del grid de estadísticas.
 * Sigue el diseño proporcionado por el diseñador.
 */
import NovedadCard from "./NovedadCard.astro";

const novedades = [
  {
    title: "Unicode presente en bienvenida de cachimbos 26-1",
    description:
      "Unicode formó parte de la fiesta que celebra el ingreso de los nuevos cachimbos UNI. Un evento lleno de risas, alegría y mucha diversión.",
    image: "/bienvenida_cachimbos.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
  {
    title: "Taller Avanzado de Robótica e IA",
    description:
      "Acompáñanos en este taller donde aprenderás a integrar modelos pre-entrenados con Arduino y Raspberry Pi para proyectos del mundo real.",
    image: "/evento_unicode_1.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
  {
    title: "Unicode presente en bienvenida de cachimbos 26-1",
    description:
      "Unicode formó parte de la fiesta que celebra el ingreso de los nuevos cachimbos UNI. Un evento lleno de risas, alegría y mucha diversión.",
    image: "/bienvenida_cachimbos.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
  {
    title: "Conoce nuestra nueva Junta Directiva 2026",
    description:
      "Con mucho orgullo anunciamos a los nuevos líderes que llevarán a UNICODE al siguiente nivel durante este periodo académico.",
    image: "/home-img2.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
  {
    title: "Unicode presente en bienvenida de cachimbos 26-1",
    description:
      "Unicode formó parte de la fiesta que celebra el ingreso de los nuevos cachimbos UNI. Un evento lleno de risas, alegría y mucha diversión.",
    image: "/bienvenida_cachimbos.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
  {
    title: "Alianzas Estratégicas y Networking",
    description:
      "Recientemente firmamos convenios con grandes referentes tecnológicos que abrirán puertas para prácticas preprofesionales a nuestros miembros.",
    image: "/evento_unicode_2.webp",
    href: "https://www.linkedin.com/company/unicode-fiis-uni/",
  },
];
---

<section id="novedades" class="w-full py-16 md:py-24 relative">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Título principal -->
    <div class="text-center mb-16">
      <h2
        class="text-4xl md:text-6xl font-bold text-unicode text-glow tracking-wider uppercase"
      >
        NOVEDADES
      </h2>
    </div>

    <!-- Carrusel de tarjetas -->
    <div class="relative group/news-carousel w-full overflow-hidden">
      <!-- "track" envuelve las tarjetas y servirá para moverlas con translate -->
      <div
        id="novedades-track"
        class="flex gap-6 lg:gap-8 pb-4 md:pb-0 transition-transform duration-700 ease-in-out cursor-grab active:cursor-grabbing w-full"
      >
        {
          novedades.map((novedad) => (
            <div class="novedad-item flex-none w-[88vw] md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1.33rem)] transition-all duration-700 ease-out transform scale-95 opacity-50">
              <NovedadCard
                title={novedad.title}
                description={novedad.description}
                image={novedad.image}
                href={novedad.href}
              />
            </div>
          ))
        }
      </div>

      <!-- Arrow Controls & Indicator (All views) -->
      <div class="flex items-center justify-center gap-6 mt-10">
        <button
          id="prev-news"
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg hover:border-unicode/50"
          aria-label="Anterior"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="3"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>

        <div
          id="novedades-carousel-indicator"
          class="flex justify-center flex-wrap gap-2 max-w-[200px]"
        >
          {
            novedades.map((_, i) => (
              <button
                class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-unicode w-6" : "bg-zinc-800"}`}
                aria-label={`Ir a novedad ${i + 1}`}
                data-index={i}
              />
            ))
          }
        </div>

        <button
          id="next-news"
          class="w-12 h-12 flex items-center justify-center bg-zinc-900 border border-zinc-800 text-unicode rounded-full active:scale-95 transition-all shadow-lg hover:border-unicode/50"
          aria-label="Siguiente"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="3"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline>
  function initNewsCarousel() {
    const track = document.getElementById("novedades-track");
    const indicator = document.getElementById("novedades-carousel-indicator");

    if (!track || !indicator) return;

    const dots = indicator.querySelectorAll("button");
    const cards = track.querySelectorAll(".novedad-item");
    const prevBtn = document.getElementById("prev-news");
    const nextBtn = document.getElementById("next-news");

    let currentIndex = 0;
    let isDragging = false;
    let startPos = 0;
    let currentTranslate = 0;
    let prevTranslate = 0;

    const getVisibleCardsCount = () => {
      if (window.innerWidth >= 1024) return 3; // lg
      if (window.innerWidth >= 768) return 2; // md
      return 1; // default mobile
    };

    const getMaxIndex = () => {
      return Math.max(0, cards.length - getVisibleCardsCount());
    };

    // Scroll by width of one item + gap
    const getScrollStep = () => {
      const firstItem = track.querySelector(".novedad-item");
      if (!firstItem) return track.clientWidth;
      const gap = parseInt(window.getComputedStyle(track).gap) || 0;
      return firstItem.offsetWidth + gap;
    };

    const updateUIState = (index) => {
      const maxIndex = getMaxIndex();

      dots.forEach((dot, i) => {
        // Ocultar dinámicamente puntos sin tarjetas a las cuales redirigir
        if (i > maxIndex) {
          dot.classList.add("hidden");
        } else {
          dot.classList.remove("hidden");
        }

        if (i === index) {
          dot.classList.add("bg-unicode", "w-6");
          dot.classList.remove("bg-zinc-800");
        } else {
          dot.classList.remove("bg-unicode", "w-6");
          dot.classList.add("bg-zinc-800");
        }
      });

      cards.forEach((card, i) => {
        const visibleCount = getVisibleCardsCount();
        if (i >= index && i < index + visibleCount) {
          // Agrandamos solo las visibles en pantalla actual
          card.classList.add("scale-100", "opacity-100");
          card.classList.remove("scale-95", "opacity-50");
        } else {
          card.classList.remove("scale-100", "opacity-100");
          card.classList.add("scale-95", "opacity-50");
        }
      });

      // Efecto visual de deshabilitar botones al llegar a límites
      if (prevBtn) {
        prevBtn.style.opacity = index <= 0 ? "0.3" : "1";
        prevBtn.style.pointerEvents = index <= 0 ? "none" : "auto";
      }
      if (nextBtn) {
        nextBtn.style.opacity = index >= maxIndex ? "0.3" : "1";
        nextBtn.style.pointerEvents = index >= maxIndex ? "none" : "auto";
      }
    };

    const setPositionByIndex = () => {
      const step = getScrollStep();
      const maxIndex = getMaxIndex();

      // Limitar índices para no ver agujeros negros
      if (currentIndex > maxIndex) currentIndex = maxIndex;
      if (currentIndex < 0) currentIndex = 0;

      currentTranslate = currentIndex * -step;
      prevTranslate = currentTranslate;
      track.style.transform = `translateX(${currentTranslate}px)`;
      updateUIState(currentIndex);
    };

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener("click", () => {
        if (currentIndex > 0) {
          currentIndex -= 1;
          setPositionByIndex();
        }
      });
      nextBtn.addEventListener("click", () => {
        if (currentIndex < getMaxIndex()) {
          currentIndex += 1;
          setPositionByIndex();
        }
      });
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        currentIndex = parseInt(dot.getAttribute("data-index") || "0");
        setPositionByIndex();
      });
    });

    // Touch Support para Móviles
    track.addEventListener("touchstart", touchStart);
    track.addEventListener("touchend", touchEnd);
    track.addEventListener("touchmove", touchMove);
    track.addEventListener("mousedown", touchStart);
    track.addEventListener("mouseup", touchEnd);
    track.addEventListener("mouseleave", () => {
      if (isDragging) touchEnd();
    });
    track.addEventListener("mousemove", touchMove);

    function touchStart(event) {
      isDragging = true;
      startPos = getPositionX(event);
      if (track)
        track.classList.remove(
          "transition-transform",
          "duration-700",
          "ease-in-out",
        );
    }

    function touchMove(event) {
      if (isDragging && track) {
        const currentPosition = getPositionX(event);
        const diff = currentPosition - startPos;
        track.style.transform = `translateX(${prevTranslate + diff}px)`;
      }
    }

    function touchEnd() {
      if (!track) return;
      isDragging = false;
      const movedBy = currentTranslate - prevTranslate;
      track.classList.add(
        "transition-transform",
        "duration-700",
        "ease-in-out",
      );

      const transformMatrix = window
        .getComputedStyle(track)
        .getPropertyValue("transform");
      let currentX = prevTranslate;
      if (transformMatrix !== "none") {
        currentX = parseFloat(transformMatrix.split(",")[4]) || 0;
      }

      const diff = currentX - prevTranslate;

      if (diff < -100 && currentIndex < getMaxIndex()) currentIndex += 1;
      if (diff > 100 && currentIndex > 0) currentIndex -= 1;

      setPositionByIndex();
    }

    function getPositionX(event) {
      return event.type.includes("mouse")
        ? event.pageX
        : event.touches[0].clientX;
    }

    // Resize event logic
    window.addEventListener("resize", () => {
      setPositionByIndex();
    });

    // Inicializar
    updateUIState(0);
  }

  // Run on initial load
  initNewsCarousel();

  // Run on Astro View Transitions
  document.addEventListener("astro:page-load", initNewsCarousel);
</script>
