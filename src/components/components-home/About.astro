---
/**
 * About.astro — Sección "¿Quiénes Somos?"
 * Presenta la misión y visión del centro cultural UNICODE
 * con un layout asimétrico para darle personalidad.
 */
---

<section id="about" class="w-full py-20 md:py-28 relative overflow-hidden">
  <!-- Glow decorativo -->
  <div
    class="absolute -right-32 top-1/2 -translate-y-1/2 w-80 h-80 bg-unicode/5 rounded-full blur-[120px] pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Columna izquierda: Texto -->
      <div class="order-2 lg:order-1">
        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-unicode/10 border border-unicode/20 text-unicode font-bold mb-6 text-xs tracking-widest uppercase"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-unicode shadow-[0_0_6px_rgba(117,211,45,0.8)]"
          ></span>
          Sobre nosotros
        </div>

        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-6 leading-[1.15]"
        >
          ¿Quiénes <span class="text-unicode text-glow">somos</span>?
        </h2>

        <p class="text-zinc-400 text-base md:text-lg leading-relaxed mb-6">
          <strong class="text-white">UNICODE</strong> es el Centro Cultural de la
          Facultad de Ingeniería Industrial y de Sistemas de la Universidad Nacional
          de Ingeniería (FIIS - UNI). Nos dedicamos a impulsar el crecimiento integral
          de los estudiantes a través de la cultura, la tecnología y la comunidad.
        </p>

        <p class="text-zinc-400 text-base md:text-lg leading-relaxed mb-8">
          Organizamos eventos, talleres y proyectos que fortalecen las
          habilidades blandas y técnicas de nuestra comunidad, creando puentes
          entre el mundo académico y el profesional.
        </p>

        <!-- Puntos clave -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div
            class="flex items-start gap-3 p-4 rounded-xl bg-zinc-900/50 border border-zinc-800/50"
          >
            <div
              class="w-8 h-8 rounded-lg bg-unicode/10 flex items-center justify-center shrink-0 mt-0.5"
            >
              <svg
                class="w-4 h-4 text-unicode"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Educación</p>
              <p class="text-zinc-500 text-xs mt-0.5">
                Talleres y capacitaciones
              </p>
            </div>
          </div>

          <div
            class="flex items-start gap-3 p-4 rounded-xl bg-zinc-900/50 border border-zinc-800/50"
          >
            <div
              class="w-8 h-8 rounded-lg bg-unicode/10 flex items-center justify-center shrink-0 mt-0.5"
            >
              <svg
                class="w-4 h-4 text-unicode"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Comunidad</p>
              <p class="text-zinc-500 text-xs mt-0.5">
                Networking y colaboración
              </p>
            </div>
          </div>

          <div
            class="flex items-start gap-3 p-4 rounded-xl bg-zinc-900/50 border border-zinc-800/50"
          >
            <div
              class="w-8 h-8 rounded-lg bg-unicode/10 flex items-center justify-center shrink-0 mt-0.5"
            >
              <svg
                class="w-4 h-4 text-unicode"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Innovación</p>
              <p class="text-zinc-500 text-xs mt-0.5">Proyectos tecnológicos</p>
            </div>
          </div>

          <div
            class="flex items-start gap-3 p-4 rounded-xl bg-zinc-900/50 border border-zinc-800/50"
          >
            <div
              class="w-8 h-8 rounded-lg bg-unicode/10 flex items-center justify-center shrink-0 mt-0.5"
            >
              <svg
                class="w-4 h-4 text-unicode"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-white font-semibold text-sm">Bienestar</p>
              <p class="text-zinc-500 text-xs mt-0.5">
                Apoyo estudiantil integral
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna derecha: Visual decorativa -->
      <div class="order-1 lg:order-2 flex justify-center">
        <div class="relative">
          <!-- Marco decorativo -->
          <div
            class="w-72 h-72 sm:w-80 sm:h-80 md:w-96 md:h-96 rounded-3xl bg-linear-to-br from-zinc-900 to-zinc-950 border border-zinc-800 flex items-center justify-center relative overflow-hidden"
          >
            <!-- Líneas decorativas -->
            <div
              class="absolute inset-0 opacity-[0.03]"
              style="background-image: repeating-linear-gradient(0deg, transparent, transparent 30px, #75D32D 30px, #75D32D 31px), repeating-linear-gradient(90deg, transparent, transparent 30px, #75D32D 30px, #75D32D 31px);"
            >
            </div>

            <!-- Logo central grande -->
            <div class="text-center relative z-10">
              <div
                class="w-24 h-24 md:w-32 md:h-32 bg-unicode/10 rounded-3xl flex items-center justify-center mx-auto mb-4 border border-unicode/20"
              >
                <span
                  class="text-5xl md:text-7xl font-extrabold text-unicode text-glow"
                  >U</span
                >
              </div>
              <p
                class="text-white font-extrabold text-xl md:text-2xl tracking-[0.3em]"
              >
                UNICODE
              </p>
              <p class="text-zinc-500 text-xs tracking-widest mt-1">
                FIIS — UNI
              </p>
            </div>

            <!-- Orbs decorativos -->
            <div
              class="absolute top-6 right-6 w-3 h-3 rounded-full bg-unicode/40 animate-pulse"
            >
            </div>
            <div
              class="absolute bottom-10 left-8 w-2 h-2 rounded-full bg-unicode/30 animate-pulse"
              style="animation-delay: 0.5s;"
            >
            </div>
            <div
              class="absolute top-1/3 left-6 w-1.5 h-1.5 rounded-full bg-unicode/20 animate-pulse"
              style="animation-delay: 1s;"
            >
            </div>
          </div>

          <!-- Elemento flotante decorativo -->
          <div
            class="absolute -top-4 -right-4 w-20 h-20 rounded-2xl bg-unicode/10 border border-unicode/20 backdrop-blur-sm flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-unicode"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
              ></path>
            </svg>
          </div>

          <!-- Elemento flotante inferior -->
          <div
            class="absolute -bottom-3 -left-3 w-16 h-16 rounded-xl bg-zinc-900 border border-zinc-800 flex items-center justify-center"
          >
            <svg
              class="w-6 h-6 text-unicode/60"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
              ></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
