---
/**
 * PorQueUnicode.astro
 * Renders the benefits of joining UNICODE in a grid layout
 * alongside the organizational mascot.
 *
 * @component
 */

interface Beneficio {
  text: string;
}

const beneficios: Beneficio[] = [
  {
    text: "Desarrolla software real y escalable desde cero, utilizando tecnologías modernas como Astro, Tailwind CSS, TypeScript y Supabase.",
  },
  {
    text: "Fortalece tu perfil profesional trabajando en entornos colaborativos bajo metodologías ágiles y adquiriendo experiencia de ingeniería.",
  },
  {
    text: "Expande tu red de contactos al conectar con programadores, diseñadores UI/UX y mentores de la industria tecnológica.",
  },
  {
    text: "Potencia tu capacidad de resolución de problemas complejos y participa en la creación de plataformas de alto impacto para la comunidad.",
  },
];
---

<section id="por-que" class="w-full py-16 md:py-24 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <div
        class="bg-[#050505]/80 border border-unicode rounded-[32px] p-8 md:p-10 shadow-[0_0_30px_rgba(117,211,45,0.1)]"
      >
        <h2
          class="text-2xl md:text-3xl font-extrabold text-unicode text-center mb-10 tracking-tight text-glow"
        >
          ¿Por qué unirse al DCC?
        </h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-8">
          {
            beneficios.map((beneficio) => (
              <div class="flex items-start gap-4">
                <div class="shrink-0 mt-1.5 md:mt-1">
                  <div class="w-2.5 h-2.5 rounded-full bg-unicode mt-0.5" />
                </div>

                <p class="text-zinc-300 text-xs md:text-[13px] leading-relaxed font-medium">
                  {beneficio.text}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <div
            class="absolute inset-0 bg-unicode/15 rounded-full blur-[90px] scale-75 pointer-events-none"
          >
          </div>

          <img
            src="/mascota/mascota-convocatoria-hd-final.png"
            alt="Mascota UNICODE"
            class="relative z-10 w-72 sm:w-80 md:w-96 lg:w-[450px] h-auto object-contain drop-shadow-[0_0_30px_rgba(117,211,45,0.25)] animate-float"
            loading="lazy"
            style="animation: float 6s ease-in-out infinite;"
          />
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes float {
      0% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
      100% {
        transform: translateY(0px);
      }
    }
  </style>
</section>
