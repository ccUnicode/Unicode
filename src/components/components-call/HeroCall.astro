---
/**
 * HeroCall.astro
 * Hero de la página de Convocatoria con imagen de fondo,
 * título, descripción, iconos de áreas y botón CTA.
 */
import { CONVOCATORIA_ABIERTA } from "../../data/siteConfig";

interface Area {
  icon: string;
  label: string;
  href: string;
}

const areas: Area[] = [
  { icon: "gth", label: "GTH", href: "/areas/gestión-del-talento-humano" },
  { icon: "acd", label: "ACD", href: "/areas/académica" },
  { icon: "rrpp", label: "RRPP", href: "/areas/relaciones-públicas" },
  {
    icon: "dcc",
    label: "DCC",
    href: "/areas/dirección-de-comunicación-y-contenido",
  },
  { icon: "id", label: "ID", href: "/areas/investigación-y-desarrollo" },
];
---

<section
  class="relative w-full min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Imagen de fondo -->
  <div class="absolute inset-0 z-0">
    <img
      src="/convocatoria-hero.webp"
      alt="Evento UNICODE"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Overlay oscuro con gradiente -->
    <div
      class="absolute inset-0 bg-linear-to-b from-black/70 via-black/60 to-[#050505]"
    >
    </div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 w-full max-w-2xl mx-auto px-6 text-center flex flex-col items-center">
    <!-- Subtítulo -->
    <p
      class="text-white text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold tracking-[0.25em] uppercase mb-2"
    >
      CONVOCATORIA
    </p>

    <!-- Título principal -->
    {CONVOCATORIA_ABIERTA ? (
      <h1
        class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold text-unicode text-glow tracking-tight leading-none mb-8"
      >
        UNICODE
      </h1>
    ) : (
      <h1
        class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold text-zinc-500 tracking-tight leading-none mb-8"
      >
        CERRADA
      </h1>
    )}

    <!-- Descripción -->
    {CONVOCATORIA_ABIERTA ? (
      <p
        class="text-zinc-300 text-sm md:text-base max-w-xl mx-auto mb-12 leading-relaxed"
      >
        Únete al Centro Cultural más grande de la FIIS UNI. Forma parte de un
        equipo que impulsa la tecnología, la cultura y la comunidad universitaria.
      </p>
    ) : (
      <p
        class="text-zinc-400 text-sm md:text-base max-w-xl mx-auto mb-12 leading-relaxed"
      >
        La convocatoria ha finalizado. ¡Gracias por tu interés! Síguenos en nuestras
        redes sociales para enterarte de la próxima convocatoria.
      </p>
    )}

    <!-- Íconos de áreas -->
    <div class="flex items-center justify-center gap-6 sm:gap-10 mb-10">
      {
        areas.map((area) => (
          <a
            href={area.href}
            class="flex flex-col items-center gap-2 group cursor-pointer"
          >
            <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center backdrop-blur-sm group-hover:border-unicode/40 group-hover:bg-unicode/10 transition-all duration-300">
              {area.icon === "gth" && (
                <svg
                  class="w-6 h-6 md:w-7 md:h-7 text-unicode"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
                  />
                </svg>
              )}
              {area.icon === "acd" && (
                <svg
                  class="w-6 h-6 md:w-7 md:h-7 text-unicode"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"
                  />
                </svg>
              )}
              {area.icon === "rrpp" && (
                <svg
                  class="w-6 h-6 md:w-7 md:h-7 text-unicode"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46"
                  />
                </svg>
              )}
              {area.icon === "dcc" && (
                <svg
                  class="w-6 h-6 md:w-7 md:h-7 text-unicode"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
                  />
                </svg>
              )}
              {area.icon === "id" && (
                <svg
                  class="w-6 h-6 md:w-7 md:h-7 text-unicode"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"
                  />
                </svg>
              )}
            </div>
            <span class="text-white font-bold text-xs md:text-sm tracking-wider group-hover:text-unicode transition-colors duration-300">
              {area.label}
            </span>
          </a>
        ))
      }
    </div>

    <!-- Botón CTA -->
    {CONVOCATORIA_ABIERTA ? (
      <a
        href="#postular"
        class="inline-block px-10 py-3.5 bg-unicode hover:bg-unicode-light text-black font-bold rounded-full transition-all duration-300 text-base shadow-unicode hover:shadow-unicode-lg transform hover:-translate-y-1"
      >
        Postula aquí
      </a>
    ) : (
      <span
        class="inline-block px-10 py-3.5 bg-zinc-800 text-zinc-500 font-bold rounded-full text-base cursor-not-allowed border border-zinc-700"
      >
        Convocatoria cerrada
      </span>
    )}
  </div>
</section>
