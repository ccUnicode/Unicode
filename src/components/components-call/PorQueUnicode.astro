---
/**
 * PorQueUnicode.astro
 * Sección "¿Por qué UNICODE?" con grid de beneficios
 * y la mascota del centro cultural.
 */

interface Beneficio {
  text: string;
}

const beneficios: Beneficio[] = [
  {
    text: "En caso hayas ingresado al área sin conocimientos previos, te irás con muchos saberes con respecto a diseño, branding y marketing.",
  },
  {
    text: "En caso hayas ingresado al área sin conocimientos previos, te irás con muchos saberes con respecto a diseño, branding y marketing.",
  },
  {
    text: "En caso hayas ingresado al área sin conocimientos previos, te irás con muchos saberes con respecto a diseño, branding y marketing.",
  },
  {
    text: "En caso hayas ingresado al área sin conocimientos previos, te irás con muchos saberes con respecto a diseño, branding y marketing.",
  },
];
---

<section id="por-que" class="w-full py-16 md:py-24 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <!-- Columna izquierda: Card de beneficios -->
      <div
        class="bg-zinc-900/60 border border-zinc-800 rounded-3xl p-8 md:p-10"
      >
        <!-- Título -->
        <h2
          class="text-2xl md:text-3xl font-extrabold text-white text-center mb-8"
        >
          ¿Por qué <span class="text-unicode text-glow">UNICODE</span>?
        </h2>

        <!-- Grid de beneficios 2x2 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            beneficios.map((beneficio) => (
              <div class="flex items-start gap-3">
                {/* Ícono de check/punto */}
                <div class="w-8 h-8 rounded-lg bg-unicode/10 border border-unicode/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg
                    class="w-4 h-4 text-unicode"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"
                    />
                  </svg>
                </div>

                {/* Texto */}
                <p class="text-zinc-400 text-xs md:text-sm leading-relaxed">
                  {beneficio.text}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Columna derecha: Mascota -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Glow detrás de la mascota -->
          <div
            class="absolute inset-0 bg-unicode/10 rounded-full blur-[80px] scale-75 pointer-events-none"
          >
          </div>

          <img
            src="/mascota_unicode.png"
            alt="Mascota UNICODE"
            class="relative z-10 w-72 sm:w-80 md:w-96 h-auto object-contain drop-shadow-[0_0_30px_rgba(117,211,45,0.2)]"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
